PORT=3000
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ja_agendou
DB_USER=seu_usuario
DB_PASSWORD=sua_senha
SESSION_SECRET=troque_essa_chave
BASE_URL=http://localhost:3000
GA4_MEASUREMENT_ID=
FACEBOOK_PIXEL_ID=

# Super admin permanente (opcional)
SUPER_ADMIN_EMAIL=otavio@jaagendou.app
SUPER_ADMIN_NAME=MESTRE
SUPER_ADMIN_PASSWORD=Otavio2805@

# Quando true, falha de migration derruba o app no boot.
# Em produção, prefira false para evitar indisponibilidade.
MIGRATIONS_STRICT=false

# SMTP / E-mail
# Hostinger (recomendado)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contato@seudominio.com
SMTP_PASS=sua_senha_da_caixa_postal
EMAIL_FROM=contato@seudominio.com

# Alias opcionais (tambem aceitos pelo sistema)
# MAIL_HOST=smtp.hostinger.com
# MAIL_PORT=465
# MAIL_SECURE=true
# MAIL_USER=contato@seudominio.com
# MAIL_PASS=sua_senha_da_caixa_postal
# MAIL_FROM=contato@seudominio.com

# Leads comerciais da pagina de vendas
SALES_LEADS_EMAIL=otavio.garcia@outlook.com
SALES_LEADS_CC_EMAIL=no-reply@jaagendou.app

# E-mail que recebe pedidos de cadastro de teste para aprovação
TRIAL_APPROVAL_EMAIL=otavio.garcia@outlook.com

# E-mail que recebe copia quando o acesso do dentista for liberado
RELEASE_COPY_EMAIL=otavio.garcia@outlook.com

# Webhook Hotmart (opcional, mas recomendado)
# Se preenchido, o endpoint /webhooks/hotmart exige este token.
HOTMART_WEBHOOK_TOKEN=
HOTMART_AUTO_CREATE_ACCOUNT=true

# Quais eventos disparam renovação/liberação de licença.
# Exemplo padrão: PURCHASE_APPROVED,PURCHASE_COMPLETE,APPROVED
HOTMART_APPROVED_EVENTS=PURCHASE_APPROVED,PURCHASE_COMPLETE,APPROVED

# Mapeamento plano/produto/offer -> dias de licença.
# Formato: identificador:dia,identificador:dia
# Dica: use product id, product ucode, offer code, offer name ou product name.
# Exemplo:
# HOTMART_PLAN_MAPPINGS=pacote_7:7,pacote_30:30,pacote_90:90,pacote_180:180,pacote_360:360
HOTMART_PLAN_MAPPINGS=

# Opcional: mapeamento por valor pago (R$) -> dias.
# Exemplo:
# HOTMART_PRICE_MAPPINGS=9.97:7,35.97:30,107.91:90,215.82:180,397.00:360
HOTMART_PRICE_MAPPINGS=
