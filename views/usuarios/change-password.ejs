<%- include('../partials/header', { title: 'Minha Senha' }) %>
<%- include('../partials/sidebar', { currentPage: 'minha-senha' }) %>

<main class="content">
  <%- include('../partials/topbar', { pageTitle: 'Minha senha', subtitle: 'Atualize sua senha de acesso com segurança.' }) %>

  <section class="card form-card" style="max-width:640px;">
    <h3>Alterar senha</h3>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>

    <form method="POST" action="/usuarios/minha-senha" class="grid-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div>
        <label>Senha atual</label>
        <input type="password" name="senha_atual" required minlength="12" />
      </div>

      <div>
        <label>Nova senha</label>
        <input type="password" name="nova_senha" required minlength="12" />
      </div>

      <div>
        <label>Confirmar nova senha</label>
        <input type="password" name="confirmar_senha" required minlength="12" />
      </div>

      <div class="form-actions full-width">
        <button type="submit" class="btn">Salvar nova senha</button>
      </div>
    </form>
  </section>
</main>

</body>
</html>