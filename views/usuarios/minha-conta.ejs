<%- include('../partials/header', { title: 'Minha Conta' }) %>
<%- include('../partials/sidebar', { currentPage: 'minha-conta' }) %>

<main class="content">
  <%- include('../partials/topbar', { pageTitle: 'Minha Conta', subtitle: 'Gerencie seus dados e da clínica.' }) %>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error" style="max-width:640px"><%= error %></div>
  <% } %>
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success" style="max-width:640px"><%= success %></div>
  <% } %>

  <div style="max-width:640px">

    <!-- Dados do recibo -->
    <section class="card form-card">
      <h3>Dados do recibo</h3>
      <p style="font-size:13px;color:#6b7280;margin-bottom:14px">Esses dados aparecem na assinatura dos recibos emitidos pela sua clínica.</p>
      <form method="POST" action="/usuarios/minha-conta" class="grid-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="action" value="update_clinic" />
        <div>
          <label>Nome do responsável</label>
          <input type="text" name="responsavel_nome" value="<%= clinica.responsavel_nome || '' %>" placeholder="Ex.: Dr. João Silva" />
        </div>
        <div>
          <label>CPF do responsável</label>
          <input type="text" name="responsavel_cpf" value="<%= clinica.responsavel_cpf || '' %>" placeholder="000.000.000-00" />
        </div>
        <div>
          <label>Cidade (recibo)</label>
          <input type="text" name="cidade" value="<%= clinica.cidade || '' %>" placeholder="Ex.: São Paulo" />
        </div>
        <div class="form-actions full-width">
          <button type="submit" class="btn">Salvar dados</button>
        </div>
      </form>
    </section>

    <!-- Alterar senha -->
    <section class="card form-card">
      <h3>Alterar senha</h3>
      <form method="POST" action="/usuarios/minha-conta" class="grid-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="action" value="change_password" />
        <div>
          <label>Senha atual</label>
          <input type="password" name="senha_atual" required minlength="6" />
        </div>
        <div>
          <label>Nova senha</label>
          <input type="password" name="nova_senha" required minlength="6" />
        </div>
        <div>
          <label>Confirmar nova senha</label>
          <input type="password" name="confirmar_senha" required minlength="6" />
        </div>
        <div class="form-actions full-width">
          <button type="submit" class="btn">Salvar nova senha</button>
        </div>
      </form>
    </section>

  </div>
</main>

</body>
</html>
