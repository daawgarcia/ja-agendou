// Social Proof Toast
(function() {
  const compras = [
    { nome: 'Dr. Eduardo B.', cidade: 'Campinas, SP', min: 3 },
    { nome: 'Dra. Patrícia M.', cidade: 'Porto Alegre, RS', min: 7 },
    { nome: 'Dr. Henrique C.', cidade: 'Belo Horizonte, MG', min: 11 },
    { nome: 'Dra. Renata O.', cidade: 'Brasília, DF', min: 19 },
    { nome: 'Dr. André L.', cidade: 'Curitiba, PR', min: 25 },
    { nome: 'Dra. Isabela F.', cidade: 'São Paulo, SP', min: 34 },
    { nome: 'Dr. Marcos T.', cidade: 'Fortaleza, CE', min: 41 },
    { nome: 'Dra. Juliana R.', cidade: 'Recife, PE', min: 53 },
    { nome: 'Dr. Rafael S.', cidade: 'Goiânia, GO', min: 62 },
    { nome: 'Dra. Camila V.', cidade: 'Florianópolis, SC', min: 78 },
  ];

  const toast   = document.getElementById('sp-toast');
  const elNome  = document.getElementById('sp-toast-name');
  const elTime  = document.getElementById('sp-toast-time');
  let idx = 0;

  function fmtTime(min) {
    if (min < 60) return 'há ' + min + ' min';
    const h = Math.floor(min / 60);
    return 'há ' + h + (h === 1 ? ' hora' : ' horas');
  }

  function show() {
    const c = compras[idx % compras.length];
    elNome.textContent = c.nome + ' · ' + c.cidade;
    elTime.textContent = fmtTime(c.min);
    toast.style.transform = 'translateY(0)';
    toast.style.opacity = '1';
    toast.style.pointerEvents = 'auto';
    setTimeout(() => {
      toast.style.transform = 'translateY(120%)';
      toast.style.opacity = '0';
      toast.style.pointerEvents = 'none';
    }, 5000);
    idx++;
    setTimeout(show, 20000 + Math.random() * 15000);
  }

  setTimeout(show, 10000);
})();
</script>

