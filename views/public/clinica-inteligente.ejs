<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --navy:    #0D1B40;
  --navy2:   #162354;
  --ouro:    #C9A84C;
  --ouro2:   #A88A35;
  --green:   #2ECC71;
  --green2:  #27AE60;
  --red:     #E74C3C;
  --white:   #FFFFFF;
  --lgray:   #F6F6F8;
  --mgray:   #8A9BB0;
  --dgray:   #2D3E55;
  --border:  #E0E6EF;
}

html { scroll-behavior: smooth; }
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: var(--dgray); background: #fff; line-height: 1.6; }

/* ── TOP BAR ── */
.top-bar {
  background: linear-gradient(90deg, var(--navy) 0%, var(--navy2) 100%);
  border-bottom: 3px solid var(--ouro);
  color: #fff;
  text-align: center;
  padding: 11px 20px;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.2px;
  position: sticky;
  top: 0;
  z-index: 100;
}
.top-bar em { color: var(--ouro); font-style: normal; }

/* ── NAV ── */
.ci-nav {
  max-width: 1080px;
  margin: 0 auto;
  padding: 18px 24px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
}
.ci-logo { color: var(--navy); font-size: 15px; font-weight: 800; text-decoration: none; display: flex; align-items: center; gap: 8px; }
.ci-logo span { color: var(--ouro); }
.ci-nav-links { display: flex; gap: 24px; align-items: center; }
.ci-nav-links a { color: var(--dgray); text-decoration: none; font-size: 14px; font-weight: 500; transition: color 0.15s; }
.ci-nav-links a:hover { color: var(--navy); }
.btn-nav-cta { background: var(--ouro); color: var(--navy) !important; font-weight: 800 !important; padding: 9px 22px; border-radius: 8px; font-size: 14px !important; white-space: nowrap; }
.btn-nav-cta:hover { background: var(--ouro2) !important; }

/* ── HERO ── */
.ci-hero {
  background: var(--navy);
  padding: 70px 24px 80px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.ci-hero::before {
  content: '';
  position: absolute;
  top: -120px; right: -120px;
  width: 500px; height: 500px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(201,168,76,0.09) 0%, transparent 70%);
}
.ci-hero::after {
  content: '';
  position: absolute;
  bottom: -80px; left: -80px;
  width: 360px; height: 360px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(201,168,76,0.06) 0%, transparent 70%);
}
.ci-hero-inner { max-width: 820px; margin: 0 auto; position: relative; z-index: 1; }
.hero-pretag {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(201,168,76,0.15);
  border: 1px solid rgba(201,168,76,0.4);
  color: var(--ouro);
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 7px 18px;
  border-radius: 30px;
  margin-bottom: 28px;
}
.ci-hero h1 {
  color: #fff;
  font-size: clamp(28px, 5.5vw, 52px);
  font-weight: 900;
  line-height: 1.1;
  margin-bottom: 10px;
}
.ci-hero h1 em { color: var(--ouro); font-style: normal; }
.ci-hero-sub-title {
  color: rgba(255,255,255,0.65);
  font-size: clamp(16px, 2.5vw, 20px);
  font-weight: 400;
  margin-bottom: 32px;
  max-width: 600px;
  margin-left: auto;
  margin-right: auto;
}

/* PROMISE PILLS */
.promise-pills {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10px;
  margin-bottom: 36px;
}
.promise-pill {
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.12);
  color: rgba(255,255,255,0.8);
  font-size: 13px;
  font-weight: 600;
  padding: 7px 16px;
  border-radius: 30px;
  display: flex;
  align-items: center;
  gap: 6px;
}
.promise-pill .pi { color: var(--ouro); }

/* HERO PRICE */
.hero-price-block {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(201,168,76,0.3);
  border-radius: 20px;
  padding: 32px 36px;
  max-width: 520px;
  margin: 0 auto 28px;
}
.hp-label { color: var(--mgray); font-size: 13px; margin-bottom: 4px; text-decoration: line-through; }
.hp-main { font-size: clamp(52px, 10vw, 76px); font-weight: 900; color: #fff; line-height: 1; }
.hp-main em { color: var(--ouro); font-style: normal; }
.hp-note { color: var(--mgray); font-size: 13px; margin-top: 6px; }
.hp-badge { display: inline-block; background: var(--red); color: #fff; font-size: 11px; font-weight: 900; padding: 4px 14px; border-radius: 20px; margin-bottom: 14px; letter-spacing: 0.5px; }

.btn-hero-cta {
  display: inline-block;
  background: linear-gradient(135deg, var(--ouro) 0%, #e0b85a 100%);
  color: var(--navy);
  font-size: clamp(17px, 2.5vw, 21px);
  font-weight: 900;
  padding: 20px 56px;
  border-radius: 50px;
  text-decoration: none;
  letter-spacing: 0.2px;
  box-shadow: 0 8px 40px rgba(201,168,76,0.5);
  animation: goldPulse 2.2s ease-in-out infinite;
  transition: transform 0.15s;
}
.btn-hero-cta:hover { transform: translateY(-3px); animation: none; box-shadow: 0 14px 50px rgba(201,168,76,0.7); }
@keyframes goldPulse { 0%, 100% { box-shadow: 0 8px 40px rgba(201,168,76,0.5); } 50% { box-shadow: 0 8px 56px rgba(201,168,76,0.8); } }

.hero-grt { color: var(--mgray); font-size: 13px; margin-top: 14px; }
.hero-grt strong { color: #fff; }

/* STATS BAR */
.ci-stats {
  background: linear-gradient(135deg, var(--ouro) 0%, #e0b85a 100%);
  padding: 44px 24px;
}
.ci-stats-grid {
  max-width: 900px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 16px;
  text-align: center;
}
.cs-num { font-size: clamp(34px, 5vw, 48px); font-weight: 900; color: var(--navy); line-height: 1; }
.cs-label { font-size: 13px; color: var(--navy2); font-weight: 600; margin-top: 6px; }

/* SECTIONS */
section { padding: 72px 24px; }
.ci-container { max-width: 900px; margin: 0 auto; }
.sec-tag { display: inline-block; color: var(--ouro2); font-size: 11px; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 10px; }
h2 { font-size: clamp(22px, 4vw, 36px); color: var(--navy); font-weight: 900; line-height: 1.2; margin-bottom: 16px; }
h2 em { color: var(--ouro); font-style: normal; }
.sec-sub { color: var(--mgray); font-size: 16px; margin-bottom: 40px; max-width: 560px; }

/* PAIN SECTION */
.pain-sec { background: var(--lgray); }
.pain-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 16px; margin-top: 32px; }
.pain-card { background: #fff; border-radius: 12px; padding: 24px; border-left: 4px solid var(--red); }
.pain-icon { font-size: 26px; margin-bottom: 10px; }
.pain-card h3 { color: var(--navy); font-size: 15px; font-weight: 700; margin-bottom: 6px; }
.pain-card p { color: var(--mgray); font-size: 13px; line-height: 1.6; }

/* FOR WHO */
.forw-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-top: 32px; }
.forw-card { border-radius: 12px; border: 1px solid var(--border); padding: 22px 20px; display: flex; gap: 14px; align-items: flex-start; }
.forw-check { color: var(--green); font-size: 20px; flex-shrink: 0; margin-top: 1px; }
.forw-card h3 { font-size: 14px; font-weight: 700; color: var(--navy); margin-bottom: 4px; }
.forw-card p { font-size: 13px; color: var(--mgray); line-height: 1.5; }

/* MODULES */
.mod-sec { background: var(--navy); }
.mod-sec h2 { color: #fff; }
.mod-sec .sec-tag { color: var(--ouro); }
.mod-sec .sec-sub { color: var(--mgray); }
.mod-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; margin-top: 36px; }
.mod-card {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(201,168,76,0.15);
  border-radius: 14px;
  padding: 26px 22px;
  transition: border-color 0.2s, background 0.2s;
}
.mod-card:hover { border-color: rgba(201,168,76,0.4); background: rgba(255,255,255,0.07); }
.mod-num { color: var(--ouro); font-size: 11px; font-weight: 900; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 8px; }
.mod-card h3 { color: #fff; font-size: 15px; font-weight: 700; margin-bottom: 8px; }
.mod-card p { color: var(--mgray); font-size: 13px; line-height: 1.6; }
.mod-card ul { margin-top: 10px; padding: 0; list-style: none; }
.mod-card ul li { color: rgba(255,255,255,0.6); font-size: 12px; padding: 3px 0 3px 16px; position: relative; }
.mod-card ul li::before { content: '◆'; position: absolute; left: 0; color: var(--ouro); font-size: 8px; top: 5px; }

/* TRANSFORMATION */
.transf-sec { background: var(--lgray); }
.transf-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 32px; }
@media (max-width: 600px) { .transf-grid { grid-template-columns: 1fr; } }
.transf-col { border-radius: 14px; padding: 28px 24px; }
.transf-col.before { background: #fff; border: 2px solid var(--border); }
.transf-col.after { background: var(--navy); border: 2px solid rgba(201,168,76,0.3); }
.transf-title { font-size: 13px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 16px; }
.transf-col.before .transf-title { color: var(--mgray); }
.transf-col.after .transf-title { color: var(--ouro); }
.transf-item { display: flex; gap: 10px; align-items: flex-start; padding: 10px 0; border-bottom: 1px solid; }
.transf-col.before .transf-item { border-color: var(--border); }
.transf-col.after .transf-item { border-color: rgba(255,255,255,0.07); }
.transf-item:last-child { border-bottom: none; }
.ti-icon { font-size: 16px; flex-shrink: 0; margin-top: 2px; }
.transf-col.before .ti-text { color: var(--mgray); font-size: 14px; line-height: 1.5; }
.transf-col.after .ti-text { color: rgba(255,255,255,0.85); font-size: 14px; line-height: 1.5; }

/* TESTIMONIALS */
.test-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-top: 36px; }
.test-card { background: var(--lgray); border-radius: 14px; padding: 26px; position: relative; }
.test-card::before { content: '"'; position: absolute; top: 14px; left: 20px; font-size: 52px; color: var(--ouro); font-family: Georgia, serif; line-height: 1; opacity: 0.3; }
.test-stars { color: var(--ouro); font-size: 14px; margin-bottom: 10px; }
.test-text { color: var(--dgray); font-size: 14px; line-height: 1.7; margin-bottom: 14px; font-style: italic; }
.test-author { font-weight: 700; color: var(--navy); font-size: 13px; }
.test-role { color: var(--mgray); font-size: 12px; }

/* WHAT YOU GET */
.wdg-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 16px; margin-top: 32px; }
.wdg-card { background: var(--lgray); border-radius: 12px; padding: 22px; display: flex; gap: 14px; }
.wdg-icon { width: 44px; height: 44px; border-radius: 10px; background: var(--navy); color: var(--ouro); font-size: 20px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.wdg-card h3 { font-size: 14px; font-weight: 700; color: var(--navy); margin-bottom: 4px; }
.wdg-card p { font-size: 12px; color: var(--mgray); line-height: 1.5; }

/* COMPARE TABLE */
.compare-table { width: 100%; border-collapse: collapse; margin-top: 36px; border-radius: 14px; overflow: hidden; }
.compare-table th { padding: 14px 20px; font-size: 13px; font-weight: 800; text-align: center; }
.compare-table th:first-child { text-align: left; }
.compare-table th:nth-child(2) { background: var(--lgray); color: var(--mgray); }
.compare-table th:nth-child(3) { background: var(--ouro); color: var(--navy); }
.compare-table td { padding: 12px 20px; font-size: 14px; border-bottom: 1px solid var(--border); text-align: center; }
.compare-table td:first-child { text-align: left; color: var(--dgray); font-weight: 500; }
.compare-table td:nth-child(2) { color: var(--mgray); }
.compare-table td:nth-child(3) { color: var(--green2); font-weight: 700; }
.compare-table tr:last-child td { border-bottom: none; }
.compare-table tr:hover td { background: var(--lgray); }

/* PRICE BOX */
.price-sec { background: var(--navy); text-align: center; }
.price-sec h2 { color: #fff; }
.price-sec .sec-sub { color: var(--mgray); margin: 0 auto 40px; }
.price-box {
  background: rgba(255,255,255,0.04);
  border: 2px solid rgba(201,168,76,0.45);
  border-radius: 24px;
  padding: 48px 44px;
  max-width: 540px;
  margin: 0 auto;
  position: relative;
  overflow: hidden;
}
.price-box::before {
  content: 'MELHOR OFERTA';
  position: absolute;
  top: 20px; right: -30px;
  background: var(--ouro);
  color: var(--navy);
  font-size: 10px;
  font-weight: 900;
  letter-spacing: 0.8px;
  padding: 6px 40px;
  transform: rotate(35deg);
}
.pb-original { color: var(--mgray); font-size: 16px; text-decoration: line-through; margin-bottom: 4px; }
.pb-disc { background: var(--red); color: #fff; font-size: 12px; font-weight: 800; padding: 4px 14px; border-radius: 20px; display: inline-block; margin-bottom: 12px; }
.pb-main { font-size: clamp(58px, 11vw, 82px); font-weight: 900; color: #fff; line-height: 1; margin-bottom: 6px; }
.pb-main em { color: var(--ouro); font-style: normal; }
.pb-note { color: var(--mgray); font-size: 14px; margin-bottom: 6px; }
.pb-install { color: rgba(255,255,255,0.55); font-size: 12px; margin-bottom: 28px; }
.pb-includes { text-align: left; margin-bottom: 32px; }
.pb-includes li { list-style: none; display: flex; align-items: center; gap: 10px; color: rgba(255,255,255,0.85); font-size: 14px; padding: 7px 0; border-bottom: 1px solid rgba(255,255,255,0.06); }
.pb-includes li:last-child { border-bottom: none; }
.pb-includes li .ci-check { color: var(--ouro); font-weight: 700; font-size: 15px; }
.btn-price-cta {
  display: block;
  width: 100%;
  text-align: center;
  background: linear-gradient(135deg, var(--ouro) 0%, #e0b85a 100%);
  color: var(--navy);
  font-size: clamp(16px, 2.5vw, 19px);
  font-weight: 900;
  padding: 20px;
  border-radius: 50px;
  text-decoration: none;
  box-shadow: 0 8px 40px rgba(201,168,76,0.45);
  animation: goldPulse 2.2s ease-in-out infinite;
  transition: transform 0.15s;
  margin-bottom: 12px;
}
.btn-price-cta:hover { transform: translateY(-3px); animation: none; }
.pb-sec-note { color: var(--mgray); font-size: 12px; }

/* GUARANTEE */
.grt-sec { text-align: center; background: #fff; }
.grt-badge { width: 120px; height: 120px; background: linear-gradient(135deg, var(--ouro) 0%, #e0b85a 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 54px; margin: 0 auto 24px; box-shadow: 0 10px 50px rgba(201,168,76,0.4); }
.grt-sec h2 { max-width: 520px; margin: 0 auto 16px; }
.grt-sec p { max-width: 540px; margin: 0 auto 24px; color: var(--mgray); font-size: 16px; line-height: 1.8; }
.grt-badge-txt { display: inline-block; background: rgba(201,168,76,0.1); border: 2px solid var(--ouro); border-radius: 12px; padding: 12px 30px; color: var(--ouro2); font-weight: 800; font-size: 15px; }

/* FAQ */
.faq-sec { background: var(--lgray); }
.faq-list { margin-top: 32px; }
.faq-item { background: #fff; border-radius: 10px; margin-bottom: 10px; overflow: hidden; border: 1px solid var(--border); }
.faq-q { padding: 18px 20px; font-weight: 700; color: var(--navy); font-size: 15px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; user-select: none; }
.faq-q::after { content: '+'; font-size: 20px; color: var(--ouro); transition: transform 0.2s; flex-shrink: 0; margin-left: 12px; }
.faq-item.open .faq-q::after { content: '−'; }
.faq-a { display: none; padding: 0 20px 18px; color: var(--mgray); font-size: 14px; line-height: 1.7; }
.faq-item.open .faq-a { display: block; }

/* FINAL CTA */
.final-cta {
  background: var(--navy);
  text-align: center;
  padding: 88px 24px;
  position: relative;
  overflow: hidden;
}
.final-cta::before {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 700px; height: 700px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(201,168,76,0.07) 0%, transparent 70%);
}
.final-cta h2 { color: #fff; max-width: 640px; margin: 0 auto 12px; position: relative; }
.final-cta p { color: var(--mgray); max-width: 480px; margin: 0 auto 36px; position: relative; }
.final-cta .btn-hero-cta { position: relative; }
.fct-price { color: rgba(255,255,255,0.55); font-size: 15px; margin-bottom: 8px; position: relative; }
.fct-price strong { color: var(--ouro); font-size: 30px; font-weight: 900; }

/* STICKY CTA */
.sticky-cta {
  display: none;
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: var(--navy);
  border-top: 3px solid var(--ouro);
  padding: 12px 20px;
  z-index: 99;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}
.sc-price { color: #fff; }
.sc-price span { display: block; font-size: 11px; color: var(--mgray); }
.sc-price strong { font-size: 22px; font-weight: 900; color: var(--ouro); }
.btn-sticky {
  background: linear-gradient(135deg, var(--ouro) 0%, #e0b85a 100%);
  color: var(--navy);
  font-weight: 900;
  font-size: 14px;
  padding: 12px 26px;
  border-radius: 50px;
  text-decoration: none;
  white-space: nowrap;
}

/* FOOTER */
footer { background: #060d22; color: var(--mgray); text-align: center; padding: 28px 20px; font-size: 13px; }
footer a { color: var(--mgray); text-decoration: none; }
footer a:hover { color: var(--ouro); }

/* SOCIAL PROOF TOAST */
#sp-toast {
  position: fixed; bottom: 24px; right: 24px; z-index: 200;
  background: #fff; border-radius: 14px;
  box-shadow: 0 8px 32px rgba(13,27,64,0.18);
  border-left: 4px solid var(--ouro);
  padding: 14px 16px 14px 14px;
  max-width: 300px; width: calc(100vw - 48px);
  display: flex; align-items: center; gap: 12px;
  transform: translateY(120%); opacity: 0;
  transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1), opacity 0.3s;
  pointer-events: none;
}
#sp-toast-name { font-weight: 700; color: var(--navy); font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
