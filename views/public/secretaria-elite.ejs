  <a class="sticky-cta" href="https://pay.hotmart.com/T105550964J?off=8e5c1qbn&utm_source=landing&utm_medium=cta&utm_campaign=secretaria_elite&utm_content=checkout_sticky" target="_blank" rel="noopener noreferrer" data-track="checkout_sticky">QUERO ENTRAR AGORA</a>

  <script>
    (function () {
      // Regressivo diário: renova à meia-noite para manter urgência operacional.
      var timerEl = document.getElementById('offer-countdown');

      function pad(num) {
        return String(num).padStart(2, '0');
      }

      function updateCountdown() {
        if (!timerEl) return;

        var now = new Date();
        var end = new Date(now);
        end.setHours(23, 59, 59, 999);

        var diff = end.getTime() - now.getTime();
        if (diff < 0) diff = 0;

        var hours = Math.floor(diff / 3600000);
        var minutes = Math.floor((diff % 3600000) / 60000);
        var seconds = Math.floor((diff % 60000) / 1000);

        timerEl.textContent = pad(hours) + ':' + pad(minutes) + ':' + pad(seconds);
      }

      updateCountdown();
      setInterval(updateCountdown, 1000);

      var checkoutLinks = document.querySelectorAll('a[data-track]');

      function trackCheckoutClick(sourceLabel) {
        var payload = {
          content_name: 'Secretaria de Elite Odonto',
          value: 47.97,
          currency: 'BRL',
          source: sourceLabel
        };

        if (typeof window.fbq === 'function') {
          window.fbq('track', 'InitiateCheckout', payload);
        }

        if (typeof window.gtag === 'function') {
          window.gtag('event', 'begin_checkout', {
            currency: 'BRL',
            value: 47.97,
            items: [{ item_name: 'Secretaria de Elite Odonto', price: 47.97, quantity: 1 }],
            source: sourceLabel
          });
        }

        if (Array.isArray(window.dataLayer)) {
          window.dataLayer.push({ event: 'checkout_click', source: sourceLabel, value: 47.97, currency: 'BRL' });
        }
      }

      checkoutLinks.forEach(function (link) {
        link.addEventListener('click', function () {
          var source = link.getAttribute('data-track') || 'checkout_unknown';
          trackCheckoutClick(source);
        });
      });
    })();
  </script>

  <footer class="footer">
