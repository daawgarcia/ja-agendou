<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Secretária de Elite Odonto | Método Completo</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Source+Serif+4:opsz,wght@8..60,300;8..60,400;8..60,600;8..60,700&display=swap" rel="stylesheet" />
<%- include('../partials/tracking') %>
<style>
:root {
  --bg: #0e1716;
  --bg-soft: #142725;
  --surface: rgba(255, 255, 255, 0.04);
  --paper: #f7f2e8;
  --text: #f7f2e8;
  --muted: #c4bbac;
  --accent: #cf6a2b;
  --accent-2: #f3be62;
  --line: rgba(255, 255, 255, 0.16);
  --ok: #8fe0b7;
  --ink: #20170f;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: "Source Serif 4", serif;
  background:
    radial-gradient(980px 500px at -6% -10%, rgba(207, 106, 43, 0.24), transparent 68%),
    radial-gradient(960px 640px at 110% 0%, rgba(243, 190, 98, 0.17), transparent 68%),
    var(--bg);
  color: var(--text);
  line-height: 1.6;
}
body::after {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  opacity: 0.08;
  background-image: radial-gradient(circle at 1px 1px, #fff 1px, transparent 0);
  background-size: 16px 16px;
}
.container { width: min(1100px, 92vw); margin: 0 auto; }
.topbar {
  position: sticky;
  top: 0;
  z-index: 40;
  border-bottom: 1px solid var(--line);
  backdrop-filter: blur(6px);
  background: rgba(14, 23, 22, 0.72);
}
.topbar .container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  min-height: 56px;
}
.topbar p {
  font-size: 14px;
  color: var(--muted);
}
.topbar strong { color: var(--paper); }
.topbar .price-highlight { color: var(--accent-2); font-weight: 700; }
.hero {
  min-height: 86vh;
  display: grid;
  place-items: center;
  padding: 56px 0 44px;
}
.hero-card {
  border: 1px solid var(--line);
  background: linear-gradient(140deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.015));
  backdrop-filter: blur(5px);
  border-radius: 24px;
  padding: 40px;
  box-shadow: 0 26px 80px rgba(0, 0, 0, 0.36);
  animation: rise 620ms ease-out both;
}
.badge {
  display: inline-block;
  font-size: 12px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  border: 1px solid rgba(240, 178, 79, 0.65);
  color: var(--accent-2);
  padding: 6px 14px;
  border-radius: 999px;
  margin-bottom: 20px;
}
.quick-proof {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin: 16px 0 10px;
}
.pill {
  border: 1px solid var(--line);
  border-radius: 999px;
  padding: 8px 12px;
  font-size: 14px;
  color: var(--paper);
  background: rgba(255, 255, 255, 0.02);
}
.title {
  font-family: "Bebas Neue", sans-serif;
  letter-spacing: 0.03em;
  line-height: 0.95;
  font-size: clamp(58px, 12vw, 128px);
  margin-bottom: 18px;
}
.title span { color: var(--accent-2); }
.sub {
  font-size: clamp(18px, 2.8vw, 30px);
  color: var(--paper);
  margin-bottom: 18px;
}
.copy {
  color: var(--muted);
  font-size: 20px;
  max-width: 760px;
}
.alert-line {
  margin-top: 14px;
  color: var(--accent-2);
  font-size: 17px;
}
.cta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  margin-top: 28px;
}
.btn {
  display: inline-block;
  text-decoration: none;
  font-weight: 700;
  letter-spacing: 0.03em;
  border-radius: 14px;
  padding: 14px 20px;
  transition: transform 0.2s ease, filter 0.2s ease;
}
.btn:hover { transform: translateY(-2px); filter: brightness(1.05); }
.btn-primary {
  color: var(--ink);
  background: linear-gradient(90deg, var(--accent-2), #ffc873);
}
.btn-secondary {
  color: var(--paper);
  border: 1px solid var(--line);
  background: rgba(255, 255, 255, 0.02);
}
.section { padding: 74px 0; }
.section h2 {
  font-family: "Bebas Neue", sans-serif;
  font-size: clamp(34px, 6vw, 64px);
  letter-spacing: 0.04em;
  margin-bottom: 14px;
}
.section p.lead { color: var(--muted); font-size: 20px; margin-bottom: 22px; }
.grid {
  display: grid;
  gap: 16px;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
}
.card {
  border: 1px solid var(--line);
  border-radius: 18px;
  padding: 20px;
  background: linear-gradient(160deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01));
}
.card h3 {
  font-size: 24px;
  margin-bottom: 8px;
  color: var(--paper);
}
.card p { color: var(--muted); font-size: 17px; }
.ribbon {
  border-left: 4px solid var(--accent);
  padding: 18px 20px;
  background: rgba(201, 106, 47, 0.12);
  border-radius: 6px;
  margin: 24px 0;
  font-size: 21px;
}
.split {
  display: grid;
  gap: 18px;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
}
.checklist {
  list-style: none;
  display: grid;
  gap: 10px;
}
.checklist li {
  border: 1px solid var(--line);
  border-radius: 12px;
  background: var(--surface);
  padding: 12px 14px;
  color: var(--paper);
  font-size: 17px;
}
.checklist li::before {
  content: "✓ ";
  color: var(--ok);
  font-weight: 700;
}
.list { list-style: none; display: grid; gap: 10px; }
.list li {
  border: 1px solid var(--line);
  border-radius: 12px;
  padding: 14px 14px;
  font-size: 18px;
  color: var(--paper);
  background: var(--surface);
}
.list li strong { color: var(--accent-2); }
.offer {
  border: 1px solid rgba(240, 178, 79, 0.42);
  border-radius: 24px;
  padding: 32px;
  background:
    radial-gradient(500px 240px at 100% 0%, rgba(240, 178, 79, 0.2), transparent 65%),
    rgba(19, 34, 32, 0.66);
}
.price {
  display: flex;
  align-items: flex-end;
  gap: 10px;
  margin: 18px 0;
}
.price .from { color: var(--muted); text-decoration: line-through; font-size: 24px; }
.price .now { font-family: "Bebas Neue", sans-serif; font-size: 84px; line-height: 0.9; color: var(--accent-2); }
.price .tag { font-size: 18px; color: var(--paper); margin-bottom: 10px; }
.stack { margin-top: 12px; color: var(--muted); font-size: 17px; }
.urgency {
  margin-top: 14px;
  border: 1px solid rgba(240, 178, 79, 0.45);
  background: rgba(240, 178, 79, 0.08);
  border-radius: 12px;
  padding: 12px 14px;
}
.urgency p {
  font-size: 15px;
  color: var(--paper);
}
.timer {
  margin-top: 4px;
  font-family: "Bebas Neue", sans-serif;
  letter-spacing: 0.05em;
  font-size: 34px;
  line-height: 1;
  color: var(--accent-2);
}
.guarantee {
  margin-top: 16px;
  border: 1px dashed rgba(144, 217, 178, 0.6);
  color: var(--ok);
  border-radius: 12px;
  padding: 12px;
  font-size: 16px;
}
.obs {
  margin-top: 10px;
  font-size: 14px;
  color: var(--muted);
}
.faq details {
  border: 1px solid var(--line);
  border-radius: 12px;
  padding: 12px 14px;
  margin-bottom: 10px;
  background: rgba(255, 255, 255, 0.02);
}
.faq summary {
  cursor: pointer;
  font-size: 19px;
  color: var(--paper);
  font-weight: 600;
}
.faq p { margin-top: 10px; color: var(--muted); font-size: 17px; }
.sticky-cta {
  position: fixed;
  right: 18px;
  bottom: 16px;
  z-index: 50;
  padding: 12px 16px;
  border-radius: 12px;
  border: 1px solid rgba(243, 190, 98, 0.75);
  background: linear-gradient(90deg, var(--accent-2), #ffc873);
  color: var(--ink);
  text-decoration: none;
  font-weight: 800;
  letter-spacing: 0.03em;
  box-shadow: 0 12px 28px rgba(0, 0, 0, 0.32);
}
.footer {
  padding: 40px 0 70px;
  text-align: center;
  color: var(--muted);
  font-size: 15px;
}
@keyframes rise {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
@media (max-width: 720px) {
  .topbar .container { min-height: 52px; }
  .topbar p { font-size: 12px; }
  .hero-card { padding: 26px; }
  .copy { font-size: 18px; }
  .ribbon { font-size: 19px; }
  .price .now { font-size: 62px; }
  .sticky-cta {
    left: 12px;
    right: 12px;
    text-align: center;
  }
}
</style>
</head>
<body>
  <div class="topbar">
    <div class="container">
      <p><strong>Oferta de lançamento</strong> por <span class="price-highlight">R$ 47,97</span> + garantia de 7 dias.</p>
