// ── EXIT-INTENT POPUP ──
(function() {
  const popup = document.getElementById('exit-popup');
  const closeBtn = document.getElementById('exit-popup-close');
  const dismissBtn = document.getElementById('exit-popup-dismiss');
  const ctaBtn = document.getElementById('exit-popup-cta');
  const storageKey = 'kitExitShown_v1';

  let shown = false;

  function canShow() {
    const last = localStorage.getItem(storageKey);
    if (!last) return true;
    return (Date.now() - Number(last)) > 2 * 24 * 60 * 60 * 1000;
  }

  function openPopup() {
    if (shown || !canShow()) return;
    shown = true;
    localStorage.setItem(storageKey, String(Date.now()));
    popup.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closePopup() {
    popup.classList.remove('active');
    document.body.style.overflow = '';
  }

  // Exit-intent: mouse sai pelo topo
  document.addEventListener('mouseleave', function(e) {
    if (e.clientY <= 0) openPopup();
  });

  // Mobile: scroll para cima rápido (comportamento de "voltar")
  let lastScrollY = window.scrollY;
  let ticking = false;
  window.addEventListener('scroll', function() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(function() {
      const delta = lastScrollY - window.scrollY;
      if (delta > 80 && window.scrollY < 300) openPopup();
      lastScrollY = window.scrollY;
      ticking = false;
    });
  }, { passive: true });

  closeBtn.addEventListener('click', closePopup);
  dismissBtn.addEventListener('click', closePopup);
  popup.addEventListener('click', function(e) { if (e.target === popup) closePopup(); });
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closePopup(); });

  // Captura de e-mail bônus
  const emailInput = document.getElementById('exit-email-input');
  const emailBtn   = document.getElementById('exit-email-btn');
  const emailMsg   = document.getElementById('exit-email-msg');

  emailBtn.addEventListener('click', async function() {
    const email = emailInput.value.trim();
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      emailMsg.textContent = 'Digite um e-mail válido.';
      emailMsg.style.color = '#ff6b6b';
      emailMsg.style.display = 'block';
      return;
    }
    emailBtn.disabled = true;
    emailBtn.textContent = 'Enviando...';
    try {
      const res = await fetch('/kit-recepcao/lead', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-csrf-token': '<%= locals.csrfToken || "" %>'
        },
        body: JSON.stringify({ email })
      });
      const data = await res.json();
      if (data.ok) {
        document.getElementById('exit-lead-form').innerHTML = '';
        emailMsg.textContent = '✅ Pronto! Confira sua caixa de entrada em breve.';
        emailMsg.style.color = 'var(--green)';
        emailMsg.style.display = 'block';
        emailMsg.style.fontSize = '14px';
        emailMsg.style.fontWeight = '700';
        document.getElementById('exit-lead-form').appendChild(emailMsg);
      } else {
        emailMsg.textContent = 'Não foi possível salvar. Tente novamente.';
        emailMsg.style.color = '#ff6b6b';
        emailMsg.style.display = 'block';
        emailBtn.disabled = false;
        emailBtn.textContent = 'Quero o bônus';
      }
    } catch(e) {
      emailMsg.textContent = 'Erro de conexão. Tente novamente.';
      emailMsg.style.color = '#ff6b6b';
      emailMsg.style.display = 'block';
      emailBtn.disabled = false;
      emailBtn.textContent = 'Quero o bônus';
    }
  });

  emailInput.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') emailBtn.click();
  });

  ctaBtn.addEventListener('click', function() {
    closePopup();
<% if (locals.facebookPixelId) { %>
    if (typeof fbq !== 'undefined') fbq('track', 'InitiateCheckout', { value: 9.97, currency: 'BRL', content_name: 'Kit Recepção - Exit Popup' });
<% } %>
  });
})();

<% if (locals.facebookPixelId) { %>
document.querySelectorAll('a[href*="hotmart.com"]').forEach(a => {
  a.addEventListener('click', () => {
    if (typeof fbq !== 'undefined') {
      fbq('track', 'InitiateCheckout', { value: 9.97, currency: 'BRL', content_name: 'Kit Recepção Profissional' });
    }
  });
});
<% } %>
</script>

