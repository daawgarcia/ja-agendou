(function() {
  const compras = [
    { nome: 'Dra. Camila R.', cidade: 'São Paulo, SP', min: 2 },
    { nome: 'Dr. Felipe M.', cidade: 'Curitiba, PR', min: 5 },
    { nome: 'Dra. Larissa T.', cidade: 'Belo Horizonte, MG', min: 8 },
    { nome: 'Dra. Juliana F.', cidade: 'Rio de Janeiro, RJ', min: 12 },
    { nome: 'Dr. Rodrigo A.', cidade: 'Porto Alegre, RS', min: 17 },
    { nome: 'Dra. Beatriz S.', cidade: 'Fortaleza, CE', min: 23 },
    { nome: 'Dr. Lucas N.', cidade: 'Brasília, DF', min: 31 },
    { nome: 'Dra. Mariana P.', cidade: 'Recife, PE', min: 38 },
    { nome: 'Dr. André L.', cidade: 'Goiânia, GO', min: 44 },
    { nome: 'Dra. Isabela C.', cidade: 'Salvador, BA', min: 51 },
    { nome: 'Dr. Thiago V.', cidade: 'Manaus, AM', min: 58 },
    { nome: 'Dra. Renata O.', cidade: 'Florianópolis, SC', min: 67 },
  ];

  const toast   = document.getElementById('sp-toast');
  const elNome  = document.getElementById('sp-name');
  const elTime  = document.getElementById('sp-time');

  let idx = 0;

  function fmtTime(min) {
    if (min < 60) return 'há ' + min + ' min';
    const h = Math.floor(min / 60);
    return 'há ' + h + (h === 1 ? ' hora' : ' horas');
  }

  function show() {
    const c = compras[idx % compras.length];
    elNome.textContent = c.nome + ' · ' + c.cidade;
    elTime.textContent = fmtTime(c.min);
    toast.style.transform = 'translateY(0)';
    toast.style.opacity = '1';
    toast.style.pointerEvents = 'auto';

    setTimeout(() => {
      toast.style.transform = 'translateY(120%)';
      toast.style.opacity = '0';
      toast.style.pointerEvents = 'none';
    }, 5000);

    idx++;
    // intervalo aleatório entre 18s e 35s
    setTimeout(show, 18000 + Math.random() * 17000);
  }

  // primeira exibição após 8s na página
  setTimeout(show, 8000);
})();

