.oferta-includes li:last-child { border-bottom: none; }
.oi-check { color: var(--accent); font-weight: 900; font-size: 15px; flex-shrink: 0; }
.btn-full { display: block; width: 100%; text-align: center; }
.oferta-sec-note { color: var(--gray); font-size: 12px; text-align: center; margin-top: 12px; }

/* ── GARANTIA ── */
.garantia { background: var(--navy); padding: 88px 24px; }
.garantia-inner { max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: auto 1fr; gap: 60px; align-items: center; }
.garantia-img { width: 200px; flex-shrink: 0; }
.garantia-img img { width: 100%; filter: drop-shadow(0 10px 30px rgba(201,168,76,0.2)); }
.garantia-text h2 { margin-bottom: 16px; }
.garantia-text p { color: var(--gray); font-size: 16px; line-height: 1.8; margin-bottom: 20px; }
.garantia-badge { display: inline-block; background: rgba(74,158,255,0.1); border: 2px solid var(--accent); border-radius: 12px; padding: 12px 28px; color: var(--accent); font-weight: 800; font-size: 15px; }

/* ── FAQ ── */
.faq { background: var(--navy2); padding: 88px 24px; }
.faq-inner { max-width: 820px; margin: 0 auto; }
.faq-list { margin-top: 40px; }
.faq-item { background: rgba(255,255,255,0.03); border: 1px solid rgba(74,158,255,0.12); border-radius: 12px; margin-bottom: 10px; overflow: hidden; }
.faq-q { padding: 20px 22px; font-weight: 700; color: #fff; font-size: 15px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 16px; user-select: none; }
.faq-q::after { content: '+'; font-size: 22px; color: var(--accent); flex-shrink: 0; }
.faq-item.open .faq-q::after { content: '−'; }
.faq-a { display: none; padding: 0 22px 20px; color: var(--gray); font-size: 14px; line-height: 1.8; }
.faq-item.open .faq-a { display: block; }

/* ── CTA FINAL ── */
.cta-final { background: var(--navy); padding: 0; overflow: hidden; }
.cta-final img { width: 100%; display: block; max-height: 400px; object-fit: cover; object-position: center; }
.cta-final-box { background: var(--navy2); padding: 72px 24px; text-align: center; }
.cta-final-box h2 { max-width: 640px; margin: 0 auto 16px; }
.cta-final-box p { color: var(--gray); max-width: 520px; margin: 0 auto 40px; font-size: 16px; line-height: 1.7; }
.cta-pills { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; margin-bottom: 36px; }
.cta-pill { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.75); font-size: 13px; font-weight: 600; padding: 7px 16px; border-radius: 30px; }

/* ── FOOTER ── */
footer { background: #030a14; color: var(--gray); text-align: center; padding: 28px 20px; font-size: 13px; }
footer a { color: var(--gray); text-decoration: none; }
footer a:hover { color: var(--accent); }

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  .hero-inner { grid-template-columns: 1fr; gap: 40px; }
  .hero-img-wrap { order: -1; }
  .hero-img-wrap img { max-width: 320px; }
  .problema-inner { grid-template-columns: 1fr; gap: 40px; }
  .oferta-inner { grid-template-columns: 1fr; gap: 40px; text-align: center; }
  .oferta-img { display: flex; justify-content: center; }
  .oferta-img img { max-width: 260px; }
  .garantia-inner { grid-template-columns: 1fr; gap: 32px; text-align: center; }
  .garantia-img { width: 140px; margin: 0 auto; }
  .preview-imgs { grid-template-columns: 1fr; }
  .preview-imgs .full { grid-column: 1; }
  .nav-cta { display: none; }
  .oferta-box { padding: 32px 22px; }
}
</style>
</head>
