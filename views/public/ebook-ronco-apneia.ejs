<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --navy: #07101e;
  --navy2: #0d1a2e;
  --navy3: #132238;
  --accent: #4a9eff;
  --accent2: #7bbeff;
  --ouro: #c9a84c;
  --ouro2: #e8c97a;
  --green: #2ecc71;
  --red: #e74c3c;
  --white: #ffffff;
  --gray: #8a9bb0;
  --text: #bdd0e4;
}
html { scroll-behavior: smooth; }
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: var(--text); background: var(--navy); line-height: 1.6; overflow-x: hidden; }

/* ── TOP BAR ── */
.top-bar {
  background: linear-gradient(90deg, #0d1a2e 0%, #132238 100%);
  border-bottom: 2px solid var(--ouro);
  color: #fff;
  text-align: center;
  padding: 10px 20px;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.3px;
}
.top-bar em { color: var(--ouro2); font-style: normal; }

/* ── NAV ── */
nav { background: rgba(7,16,30,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(74,158,255,0.1); position: sticky; top: 0; z-index: 100; }
.nav-inner { max-width: 1100px; margin: 0 auto; padding: 14px 24px; display: flex; justify-content: space-between; align-items: center; }
.nav-logo { color: #fff; font-size: 15px; font-weight: 800; text-decoration: none; }
.nav-logo span { color: var(--accent); }
.nav-cta { background: var(--accent); color: var(--navy); font-size: 13px; font-weight: 800; padding: 8px 22px; border-radius: 30px; text-decoration: none; transition: opacity 0.2s; }
.nav-cta:hover { opacity: 0.85; }

/* ── HERO ── */
.hero {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy2) 60%, #0f2040 100%);
  padding: 80px 24px 90px;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 70% 60% at 70% 50%, rgba(74,158,255,0.07) 0%, transparent 70%);
  pointer-events: none;
}
.hero-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; position: relative; z-index: 1; }
.hero-tag { display: inline-flex; align-items: center; gap: 8px; background: rgba(201,168,76,0.12); border: 1px solid rgba(201,168,76,0.35); color: var(--ouro2); font-size: 11px; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; padding: 6px 16px; border-radius: 30px; margin-bottom: 24px; }
.hero h1 { font-size: clamp(30px, 4.5vw, 50px); font-weight: 900; color: #fff; line-height: 1.1; margin-bottom: 18px; }
.hero h1 em { color: var(--accent); font-style: normal; }
.hero-sub { font-size: clamp(15px, 2vw, 18px); color: var(--gray); line-height: 1.7; margin-bottom: 32px; max-width: 480px; }
.hero-bullets { list-style: none; margin-bottom: 36px; display: flex; flex-direction: column; gap: 12px; }
.hero-bullets li { display: flex; align-items: center; gap: 12px; color: rgba(255,255,255,0.9); font-size: 15px; font-weight: 600; }
.hero-bullets li::before { content: ''; width: 20px; height: 20px; border-radius: 50%; background: linear-gradient(135deg, var(--accent), var(--accent2)); flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
.bullet-icon { width: 20px; height: 20px; border-radius: 50%; background: linear-gradient(135deg, var(--accent), var(--accent2)); display: flex; align-items: center; justify-content: center; font-size: 11px; flex-shrink: 0; }
.btn-primary {
  display: inline-block;
  background: linear-gradient(135deg, var(--accent) 0%, var(--accent2) 100%);
  color: var(--navy);
  font-size: clamp(16px, 2vw, 19px);
  font-weight: 900;
  padding: 18px 48px;
  border-radius: 50px;
  text-decoration: none;
  box-shadow: 0 8px 40px rgba(74,158,255,0.4);
  transition: transform 0.15s, box-shadow 0.15s;
  cursor: pointer;
}
.btn-primary:hover { transform: translateY(-3px); box-shadow: 0 12px 50px rgba(74,158,255,0.5); }
.btn-secondary {
  display: inline-block;
  background: transparent;
  border: 2px solid var(--accent);
  color: var(--accent);
  font-size: clamp(15px, 2vw, 17px);
  font-weight: 800;
  padding: 16px 44px;
  border-radius: 50px;
  text-decoration: none;
  transition: background 0.2s, color 0.2s;
}
.btn-secondary:hover { background: var(--accent); color: var(--navy); }
.hero-micro { color: var(--gray); font-size: 12px; margin-top: 14px; display: flex; align-items: center; gap: 6px; }
.hero-micro strong { color: rgba(255,255,255,0.7); }
.hero-img-wrap { display: flex; justify-content: center; align-items: center; }
.hero-img-wrap img { width: 100%; max-width: 520px; border-radius: 16px; filter: drop-shadow(0 20px 60px rgba(0,0,0,0.5)); }

/* ── PROBLEMA ── */
.problema { background: var(--navy2); padding: 88px 24px; }
.problema-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: center; }
.problema-img img { width: 100%; border-radius: 20px; box-shadow: 0 20px 60px rgba(0,0,0,0.4); }
.sec-tag { display: inline-block; color: var(--accent); font-size: 11px; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 12px; }
.sec-tag.gold { color: var(--ouro2); }
h2 { font-size: clamp(24px, 3.5vw, 38px); color: #fff; font-weight: 900; line-height: 1.2; margin-bottom: 20px; }
h2 em { color: var(--accent); font-style: normal; }
h2 .gold { color: var(--ouro2); }
.sec-text { color: var(--gray); font-size: 16px; line-height: 1.8; margin-bottom: 24px; }
.problema-list { list-style: none; display: flex; flex-direction: column; gap: 14px; }
.problema-list li { display: flex; align-items: flex-start; gap: 12px; color: rgba(255,255,255,0.85); font-size: 15px; line-height: 1.5; }
.pli-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); flex-shrink: 0; margin-top: 7px; }

/* ── STATS ── */
.stats { background: var(--navy); padding: 88px 24px; text-align: center; }
.stats-inner { max-width: 1100px; margin: 0 auto; }
.stats-img { margin: 48px auto 0; max-width: 820px; }
.stats-img img { width: 100%; border-radius: 20px; box-shadow: 0 20px 60px rgba(0,0,0,0.4); }
.stats-note { margin-top: 28px; color: var(--gray); font-size: 15px; font-style: italic; }

/* ── PARA QUEM ── */
.paraquem { background: var(--navy2); padding: 88px 24px; }
.paraquem-inner { max-width: 1100px; margin: 0 auto; text-align: center; }
.paraquem-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; margin-top: 48px; text-align: left; }
.pq-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(74,158,255,0.15); border-radius: 16px; padding: 28px 24px; display: flex; gap: 16px; align-items: flex-start; transition: border-color 0.2s, background 0.2s; }
.pq-card:hover { border-color: rgba(74,158,255,0.4); background: rgba(255,255,255,0.07); }
.pq-icon { font-size: 28px; flex-shrink: 0; }
.pq-card h3 { color: #fff; font-size: 15px; font-weight: 700; margin-bottom: 6px; line-height: 1.3; }
.pq-card p { color: var(--gray); font-size: 13px; line-height: 1.6; }

/* ── O QUE VAI APRENDER ── */
.aprender { background: var(--navy); padding: 88px 24px; }
.aprender-inner { max-width: 1100px; margin: 0 auto; text-align: center; }
.aprender-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-top: 48px; text-align: left; }
.ap-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(74,158,255,0.12); border-radius: 14px; padding: 24px 20px; display: flex; gap: 14px; align-items: flex-start; }
.ap-num { color: var(--accent); font-size: 11px; font-weight: 900; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 6px; }
.ap-card h3 { color: #fff; font-size: 14px; font-weight: 700; line-height: 1.4; }

/* ── PREVIEW INTERNO ── */
.preview { background: var(--navy2); padding: 88px 24px; text-align: center; }
.preview-inner { max-width: 1100px; margin: 0 auto; }
.preview-imgs { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 48px; }
.preview-imgs img { width: 100%; border-radius: 16px; box-shadow: 0 10px 40px rgba(0,0,0,0.4); transition: transform 0.3s; }
.preview-imgs img:hover { transform: scale(1.02); }
.preview-imgs .full { grid-column: 1 / -1; }

/* ── CAPÍTULOS ── */
.capitulos { background: var(--navy); padding: 88px 24px; }
.capitulos-inner { max-width: 1100px; margin: 0 auto; text-align: center; }
.cap-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 14px; margin-top: 48px; text-align: left; }
.cap-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(74,158,255,0.12); border-radius: 14px; padding: 22px 20px; transition: border-color 0.2s, background 0.2s; }
.cap-card:hover { border-color: rgba(74,158,255,0.35); background: rgba(255,255,255,0.06); }
.cap-num { color: var(--accent); font-size: 10px; font-weight: 900; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 8px; }
.cap-card h3 { color: #fff; font-size: 15px; font-weight: 700; margin-bottom: 6px; }
.cap-card p { color: var(--gray); font-size: 13px; line-height: 1.6; }

/* ── BÔNUS ── */
.bonus { background: linear-gradient(135deg, rgba(201,168,76,0.06) 0%, rgba(74,158,255,0.04) 100%); border-top: 1px solid rgba(201,168,76,0.15); border-bottom: 1px solid rgba(201,168,76,0.15); padding: 88px 24px; }
.bonus-inner { max-width: 1100px; margin: 0 auto; text-align: center; }
.bonus-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-top: 48px; text-align: left; }
.bonus-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(201,168,76,0.2); border-radius: 16px; padding: 28px 24px; position: relative; overflow: hidden; }
.bonus-card::before { content: 'BÔNUS'; position: absolute; top: 12px; right: -10px; background: var(--ouro); color: var(--navy); font-size: 9px; font-weight: 900; letter-spacing: 1px; padding: 3px 20px; transform: rotate(35deg); }
.bonus-icon { font-size: 32px; margin-bottom: 14px; }
.bonus-card h3 { color: var(--ouro2); font-size: 16px; font-weight: 800; margin-bottom: 8px; }
.bonus-card p { color: var(--gray); font-size: 13px; line-height: 1.6; }
.bonus-tag { display: inline-block; background: rgba(201,168,76,0.15); color: var(--ouro2); font-size: 10px; font-weight: 800; padding: 3px 10px; border-radius: 20px; margin-top: 10px; }

/* ── OFERTA ── */
.oferta { background: var(--navy2); padding: 88px 24px; }
.oferta-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
.oferta-img img { width: 100%; max-width: 380px; filter: drop-shadow(0 20px 50px rgba(0,0,0,0.5)); }
.oferta-box { background: rgba(255,255,255,0.04); border: 2px solid rgba(74,158,255,0.3); border-radius: 24px; padding: 44px 40px; position: relative; overflow: hidden; }
.oferta-box::after { content: 'LANÇAMENTO'; position: absolute; top: 22px; right: -28px; background: var(--accent); color: var(--navy); font-size: 10px; font-weight: 900; letter-spacing: 0.8px; padding: 6px 40px; transform: rotate(35deg); }
.oferta-original { color: var(--gray); font-size: 16px; text-decoration: line-through; margin-bottom: 4px; }
.oferta-disc { display: inline-block; background: var(--red); color: #fff; font-size: 12px; font-weight: 900; padding: 4px 14px; border-radius: 20px; margin-bottom: 14px; }
.oferta-price { font-size: clamp(56px, 10vw, 78px); font-weight: 900; color: #fff; line-height: 1; margin-bottom: 6px; }
