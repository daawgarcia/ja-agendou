<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --navy:    #0a1628;
  --navy2:   #132238;
  --navy3:   #1a2d47;
  --accent:  #4a9eff;
  --accent2: #7bbeff;
  --ouro:    #c9a84c;
  --ouro2:   #e8c97a;
  --green:   #2ecc71;
  --red:     #e74c3c;
  --white:   #ffffff;
  --cream:   #f5f0e8;
  --mgray:   #8a9bb0;
  --text:    #bdd0e4;
  --border:  rgba(74,158,255,0.15);
}

html { scroll-behavior: smooth; }
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: var(--text); background: var(--navy); line-height: 1.6; }

/* ── TOP BAR ── */
.top-bar {
  background: linear-gradient(90deg, var(--navy) 0%, var(--navy2) 100%);
  border-bottom: 3px solid var(--accent);
  color: #fff;
  text-align: center;
  padding: 11px 20px;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.2px;
  position: sticky;
  top: 0;
  z-index: 100;
}
.top-bar em { color: var(--accent); font-style: normal; }

/* ── NAV ── */
.ebook-nav {
  max-width: 1080px;
  margin: 0 auto;
  padding: 18px 24px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
}
.ebook-logo { color: #fff; font-size: 15px; font-weight: 800; text-decoration: none; display: flex; align-items: center; gap: 8px; }
.ebook-logo span { color: var(--accent); }
.ebook-nav-links { display: flex; gap: 24px; align-items: center; }
.ebook-nav-links a { color: var(--text); text-decoration: none; font-size: 14px; font-weight: 500; transition: color 0.15s; }
.ebook-nav-links a:hover { color: var(--accent); }
.btn-nav-cta { background: var(--accent); color: var(--navy) !important; font-weight: 800 !important; padding: 9px 22px; border-radius: 8px; font-size: 14px !important; white-space: nowrap; }
.btn-nav-cta:hover { background: var(--accent2) !important; }

/* ── HERO ── */
.ebook-hero {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy2) 50%, var(--navy3) 100%);
  padding: 70px 24px 80px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.ebook-hero::before {
  content: '';
  position: absolute;
  top: -120px; right: -120px;
  width: 500px; height: 500px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(74,158,255,0.12) 0%, transparent 70%);
}
.ebook-hero::after {
  content: '';
  position: absolute;
  bottom: -80px; left: -80px;
  width: 360px; height: 360px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(201,168,76,0.08) 0%, transparent 70%);
}
.ebook-hero-inner { max-width: 820px; margin: 0 auto; position: relative; z-index: 1; }
.hero-pretag {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(74,158,255,0.12);
  border: 1px solid rgba(74,158,255,0.35);
  color: var(--accent);
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 7px 18px;
  border-radius: 30px;
  margin-bottom: 28px;
}
.ebook-hero h1 {
  color: #fff;
  font-size: clamp(28px, 5.5vw, 52px);
  font-weight: 900;
  line-height: 1.1;
  margin-bottom: 10px;
}
.ebook-hero h1 em { color: var(--accent); font-style: normal; }
.ebook-hero h1 .gold { color: var(--ouro); }
.ebook-hero-sub-title {
  color: rgba(255,255,255,0.65);
  font-size: clamp(16px, 2.5vw, 20px);
  font-weight: 400;
  margin-bottom: 32px;
  max-width: 600px;
  margin-left: auto;
  margin-right: auto;
}

/* PROMISE PILLS */
.promise-pills {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10px;
  margin-bottom: 36px;
}
.promise-pill {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  color: rgba(255,255,255,0.8);
  font-size: 13px;
  font-weight: 600;
  padding: 7px 16px;
  border-radius: 30px;
  display: flex;
  align-items: center;
  gap: 6px;
}
.promise-pill .pi { color: var(--accent); }

/* HERO PRICE */
.hero-price-block {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(74,158,255,0.25);
  border-radius: 20px;
  padding: 32px 36px;
  max-width: 520px;
  margin: 0 auto 28px;
}
.hp-label { color: var(--mgray); font-size: 13px; margin-bottom: 4px; text-decoration: line-through; }
.hp-main { font-size: clamp(52px, 10vw, 76px); font-weight: 900; color: #fff; line-height: 1; }
.hp-main em { color: var(--accent); font-style: normal; }
.hp-note { color: var(--mgray); font-size: 13px; margin-top: 6px; }
.hp-badge { display: inline-block; background: var(--red); color: #fff; font-size: 11px; font-weight: 900; padding: 4px 14px; border-radius: 20px; margin-bottom: 14px; letter-spacing: 0.5px; }

.btn-hero-cta {
  display: inline-block;
  background: linear-gradient(135deg, var(--accent) 0%, var(--accent2) 100%);
  color: var(--navy);
  font-size: clamp(17px, 2.5vw, 21px);
  font-weight: 900;
  padding: 20px 56px;
  border-radius: 50px;
  text-decoration: none;
  letter-spacing: 0.2px;
  box-shadow: 0 8px 40px rgba(74,158,255,0.4);
  animation: bluePulse 2.2s ease-in-out infinite;
  transition: transform 0.15s;
}
.btn-hero-cta:hover { transform: translateY(-3px); animation: none; box-shadow: 0 14px 50px rgba(74,158,255,0.6); }
@keyframes bluePulse { 0%, 100% { box-shadow: 0 8px 40px rgba(74,158,255,0.4); } 50% { box-shadow: 0 8px 56px rgba(74,158,255,0.7); } }

.hero-grt { color: var(--mgray); font-size: 13px; margin-top: 14px; }
.hero-grt strong { color: #fff; }

/* STATS BAR */
.ebook-stats {
  background: linear-gradient(135deg, var(--accent) 0%, var(--accent2) 100%);
  padding: 44px 24px;
}
.ebook-stats-grid {
  max-width: 900px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 16px;
  text-align: center;
}
.cs-num { font-size: clamp(34px, 5vw, 48px); font-weight: 900; color: var(--navy); line-height: 1; }
.cs-label { font-size: 13px; color: var(--navy2); font-weight: 600; margin-top: 6px; }

/* SECTIONS */
section { padding: 72px 24px; }
.ebook-container { max-width: 900px; margin: 0 auto; }
.sec-tag { display: inline-block; color: var(--accent); font-size: 11px; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 10px; }
h2 { font-size: clamp(22px, 4vw, 36px); color: #fff; font-weight: 900; line-height: 1.2; margin-bottom: 16px; }
h2 em { color: var(--accent); font-style: normal; }
h2 .gold { color: var(--ouro); }
.sec-sub { color: var(--mgray); font-size: 16px; margin-bottom: 40px; max-width: 560px; }

/* PAIN SECTION */
.pain-sec { background: var(--navy2); }
.pain-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 16px; margin-top: 32px; }
.pain-card { background: rgba(255,255,255,0.04); border-radius: 12px; padding: 24px; border-left: 4px solid var(--red); }
.pain-icon { font-size: 26px; margin-bottom: 10px; }
.pain-card h3 { color: #fff; font-size: 15px; font-weight: 700; margin-bottom: 6px; }
.pain-card p { color: var(--mgray); font-size: 13px; line-height: 1.6; }

/* FOR WHO */
.forw-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-top: 32px; }
.forw-card { border-radius: 12px; border: 1px solid var(--border); padding: 22px 20px; display: flex; gap: 14px; align-items: flex-start; background: rgba(255,255,255,0.02); }
.forw-check { color: var(--accent); font-size: 20px; flex-shrink: 0; margin-top: 1px; }
.forw-card h3 { font-size: 14px; font-weight: 700; color: #fff; margin-bottom: 4px; }
.forw-card p { font-size: 13px; color: var(--mgray); line-height: 1.5; }

/* MODULES */
.mod-sec { background: var(--navy); }
.mod-sec h2 { color: #fff; }
.mod-sec .sec-tag { color: var(--accent); }
.mod-sec .sec-sub { color: var(--mgray); }
.mod-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; margin-top: 36px; }
.mod-card {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(74,158,255,0.15);
  border-radius: 14px;
  padding: 26px 22px;
  transition: border-color 0.2s, background 0.2s;
}
.mod-card:hover { border-color: rgba(74,158,255,0.4); background: rgba(255,255,255,0.07); }
.mod-num { color: var(--accent); font-size: 11px; font-weight: 900; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 8px; }
.mod-card h3 { color: #fff; font-size: 15px; font-weight: 700; margin-bottom: 8px; }
.mod-card p { color: var(--mgray); font-size: 13px; line-height: 1.6; }
.mod-card ul { margin-top: 10px; padding: 0; list-style: none; }
.mod-card ul li { color: rgba(255,255,255,0.6); font-size: 12px; padding: 3px 0 3px 16px; position: relative; }
.mod-card ul li::before { content: '◆'; position: absolute; left: 0; color: var(--accent); font-size: 8px; top: 5px; }

/* STATS CARDS */
.stats-sec { background: var(--navy2); }
.stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-top: 36px; }
.stat-card {
  background: linear-gradient(135deg, rgba(74,158,255,0.1), rgba(74,158,255,0.02));
  border: 1px solid rgba(74,158,255,0.2);
  border-radius: 18px;
  padding: 32px 24px;
  text-align: center;
  transition: transform 0.3s, border-color 0.3s;
}
.stat-card:hover { transform: translateY(-4px); border-color: rgba(74,158,255,0.4); }
.stat-number { font-size: clamp(36px, 6vw, 52px); font-weight: 900; color: var(--accent); line-height: 1; margin-bottom: 8px; }
.stat-label { font-size: 13px; color: var(--mgray); line-height: 1.5; }

/* TRANSFORMATION */
.transf-sec { background: var(--navy2); }
.transf-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 32px; }
@media (max-width: 600px) { .transf-grid { grid-template-columns: 1fr; } }
.transf-col { border-radius: 14px; padding: 28px 24px; }
.transf-col.before { background: rgba(255,255,255,0.04); border: 2px solid rgba(255,255,255,0.08); }
.transf-col.after { background: linear-gradient(135deg, rgba(74,158,255,0.1), rgba(74,158,255,0.02)); border: 2px solid rgba(74,158,255,0.25); }
.transf-title { font-size: 13px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 16px; }
.transf-col.before .transf-title { color: var(--mgray); }
.transf-col.after .transf-title { color: var(--accent); }
.transf-item { display: flex; gap: 10px; align-items: flex-start; padding: 10px 0; border-bottom: 1px solid; }
.transf-col.before .transf-item { border-color: rgba(255,255,255,0.06); }
.transf-col.after .transf-item { border-color: rgba(74,158,255,0.1); }
.transf-item:last-child { border-bottom: none; }
.ti-icon { font-size: 16px; flex-shrink: 0; margin-top: 2px; }
.transf-col.before .ti-text { color: var(--mgray); font-size: 14px; line-height: 1.5; }
.transf-col.after .ti-text { color: rgba(255,255,255,0.85); font-size: 14px; line-height: 1.5; }

/* TESTIMONIALS */
.test-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-top: 36px; }
.test-card { 
  background: rgba(255,255,255,0.04); 
  border: 1px solid var(--border);
  border-radius: 14px; 
  padding: 26px; 
  position: relative; 
}
.test-card::before { content: '"'; position: absolute; top: 14px; left: 20px; font-size: 52px; color: var(--accent); font-family: Georgia, serif; line-height: 1; opacity: 0.3; }
.test-stars { color: var(--ouro); font-size: 14px; margin-bottom: 10px; }
.test-text { color: var(--text); font-size: 14px; line-height: 1.7; margin-bottom: 14px; font-style: italic; }
.test-author { font-weight: 700; color: #fff; font-size: 13px; }
.test-role { color: var(--mgray); font-size: 12px; }

/* WHAT YOU GET */
.wdg-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 16px; margin-top: 32px; }
.wdg-card { background: rgba(255,255,255,0.04); border: 1px solid var(--border); border-radius: 12px; padding: 22px; display: flex; gap: 14px; }
.wdg-icon { width: 44px; height: 44px; border-radius: 10px; background: linear-gradient(135deg, var(--accent), var(--accent2)); color: var(--navy); font-size: 20px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.wdg-card h3 { font-size: 14px; font-weight: 700; color: #fff; margin-bottom: 4px; }
.wdg-card p { font-size: 12px; color: var(--mgray); line-height: 1.5; }

/* CASES */
.case-sec { background: var(--navy); }
.case-box {
  background: linear-gradient(135deg, rgba(201,168,76,0.08), rgba(201,168,76,0.02));
  border: 1px solid rgba(201,168,76,0.25);
  border-radius: 22px;
  padding: 36px;
  margin: 32px 0;
}
.case-label { font-size: 10px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; color: var(--ouro); margin-bottom: 16px; display: block; }
.case-box h3 { color: var(--ouro2); font-size: 20px; margin-bottom: 8px; }
.case-metrics { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 14px; margin: 20px 0; }
.case-metric { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 18px 14px; text-align: center; }
.case-metric .m-label { font-size: 10px; color: var(--mgray); letter-spacing: 0.5px; margin-bottom: 6px; }
.case-metric .m-val { font-size: 26px; font-weight: 900; color: #fff; }
.case-metric .m-val.bad { color: var(--red); }
.case-metric .m-val.good { color: var(--green); }

/* COMPARE TABLE */
.compare-table { width: 100%; border-collapse: collapse; margin-top: 36px; border-radius: 14px; overflow: hidden; }
.compare-table th { padding: 14px 20px; font-size: 13px; font-weight: 800; text-align: center; }
.compare-table th:first-child { text-align: left; }
.compare-table th:nth-child(2) { background: rgba(255,255,255,0.04); color: var(--mgray); }
.compare-table th:nth-child(3) { background: var(--accent); color: var(--navy); }
.compare-table td { padding: 12px 20px; font-size: 14px; border-bottom: 1px solid var(--border); text-align: center; }
.compare-table td:first-child { text-align: left; color: #fff; font-weight: 500; }
.compare-table td:nth-child(2) { color: var(--mgray); }
.compare-table td:nth-child(3) { color: var(--accent); font-weight: 700; }
.compare-table tr:last-child td { border-bottom: none; }
.compare-table tr:hover td { background: rgba(255,255,255,0.02); }

/* PRICE BOX */
.price-sec { background: var(--navy2); text-align: center; }
.price-sec h2 { color: #fff; }
.price-sec .sec-sub { color: var(--mgray); margin: 0 auto 40px; }
.price-box {
  background: rgba(255,255,255,0.04);
  border: 2px solid rgba(74,158,255,0.35);
  border-radius: 24px;
  padding: 48px 44px;
  max-width: 540px;
  margin: 0 auto;
  position: relative;
  overflow: hidden;
}
.price-box::before {
  content: 'OFERTA ESPECIAL';
  position: absolute;
  top: 20px; right: -30px;
  background: var(--accent);
  color: var(--navy);
  font-size: 10px;
  font-weight: 900;
  letter-spacing: 0.8px;
  padding: 6px 40px;
  transform: rotate(35deg);
}
.pb-original { color: var(--mgray); font-size: 16px; text-decoration: line-through; margin-bottom: 4px; }
.pb-disc { background: var(--red); color: #fff; font-size: 12px; font-weight: 800; padding: 4px 14px; border-radius: 20px; display: inline-block; margin-bottom: 12px; }
.pb-main { font-size: clamp(58px, 11vw, 82px); font-weight: 900; color: #fff; line-height: 1; margin-bottom: 6px; }
.pb-main em { color: var(--accent); font-style: normal; }
.pb-note { color: var(--mgray); font-size: 14px; margin-bottom: 6px; }
.pb-install { color: rgba(255,255,255,0.55); font-size: 12px; margin-bottom: 28px; }
.pb-includes { text-align: left; margin-bottom: 32px; }
.pb-includes li { list-style: none; display: flex; align-items: center; gap: 10px; color: rgba(255,255,255,0.85); font-size: 14px; padding: 7px 0; border-bottom: 1px solid rgba(255,255,255,0.06); }
.pb-includes li:last-child { border-bottom: none; }
.pb-includes li .ebook-check { color: var(--accent); font-weight: 700; font-size: 15px; }
.btn-price-cta {
  display: block;
  width: 100%;
  text-align: center;
  background: linear-gradient(135deg, var(--accent) 0%, var(--accent2) 100%);
  color: var(--navy);
  font-size: clamp(16px, 2.5vw, 19px);
  font-weight: 900;
  padding: 20px;
  border-radius: 50px;
  text-decoration: none;
  box-shadow: 0 8px 40px rgba(74,158,255,0.35);
  animation: bluePulse 2.2s ease-in-out infinite;
  transition: transform 0.15s;
  margin-bottom: 12px;
}
.btn-price-cta:hover { transform: translateY(-3px); animation: none; }
.pb-sec-note { color: var(--mgray); font-size: 12px; }

/* GUARANTEE */
.grt-sec { text-align: center; background: var(--navy); }
.grt-badge { width: 120px; height: 120px; background: linear-gradient(135deg, var(--accent) 0%, var(--accent2) 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 54px; margin: 0 auto 24px; box-shadow: 0 10px 50px rgba(74,158,255,0.3); }
.grt-sec h2 { max-width: 520px; margin: 0 auto 16px; }
.grt-sec p { max-width: 540px; margin: 0 auto 24px; color: var(--mgray); font-size: 16px; line-height: 1.8; }
.grt-badge-txt { display: inline-block; background: rgba(74,158,255,0.1); border: 2px solid var(--accent); border-radius: 12px; padding: 12px 30px; color: var(--accent); font-weight: 800; font-size: 15px; }

/* FAQ */
.faq-sec { background: var(--navy2); }
.faq-list { margin-top: 32px; }
.faq-item { background: rgba(255,255,255,0.04); border-radius: 10px; margin-bottom: 10px; overflow: hidden; border: 1px solid var(--border); }
.faq-q { padding: 18px 20px; font-weight: 700; color: #fff; font-size: 15px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; user-select: none; }
.faq-q::after { content: '+'; font-size: 20px; color: var(--accent); transition: transform 0.2s; flex-shrink: 0; margin-left: 12px; }
.faq-item.open .faq-q::after { content: '−'; }
.faq-a { display: none; padding: 0 20px 18px; color: var(--mgray); font-size: 14px; line-height: 1.7; }
.faq-item.open .faq-a { display: block; }

/* URGENCY BAR */
.urgency-bar {
