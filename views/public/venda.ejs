    <svg viewBox="0 0 32 32" width="28" height="28" fill="#fff"><path d="M16.004 0h-.008C7.174 0 0 7.176 0 16.004c0 3.5 1.128 6.744 3.046 9.378L1.054 31.29l6.118-1.958A15.9 15.9 0 0016.004 32C24.826 32 32 24.826 32 16.004S24.826 0 16.004 0zm9.338 22.594c-.39 1.1-2.286 2.1-3.15 2.166-.796.06-1.78.086-2.872-.18a26.207 26.207 0 01-2.6-.962c-4.574-1.978-7.56-6.618-7.79-6.926-.228-.308-1.868-2.486-1.868-4.742s1.182-3.366 1.602-3.826c.42-.46.916-.576 1.222-.576.304 0 .61.002.876.016.282.014.66-.108.032 1.496-.116.296-.702 1.716-.764 1.84-.062.124-.104.27-.02.432.082.162.124.264.248.408.124.144.26.322.372.432.248.248.506.518.688.698.248.248.506.534.69.716.372.372.38.692.124 1.076-.256.382-1.072 1.396-1.154 1.5-.082.106-.166.15-.03.302.136.15.608.704 1.304 1.142.894.564 1.648.74 1.884.824.236.082.374.07.512-.042s.594-.694.752-.932c.158-.238.316-.198.532-.118.218.08 1.378.65 1.614.768.236.118.394.178.452.274.058.096.058.556-.332 1.656z"/></svg>
