  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const modal = document.querySelector('[data-trial-modal]');
      const openButtons = document.querySelectorAll('[data-open-trial-popup]');
      const closeButtons = document.querySelectorAll('[data-close-trial-popup]');
      const storageKey = 'jaagendou-popup-ts';

      var popupShown = false;

      function canShowPopup() {
        var last = localStorage.getItem(storageKey);
        if (!last) return true;
        return (Date.now() - Number(last)) > 3 * 24 * 60 * 60 * 1000; // 3 dias
      }

      function openModal() {
        if (!modal) return;
        modal.hidden = false;
        document.body.classList.add('sales-modal-open');
        var firstField = modal.querySelector('input[name="nome_responsavel"]');
        if (firstField) firstField.focus();
      }

      function closeModal() {
        if (!modal) return;
        modal.hidden = true;
        document.body.classList.remove('sales-modal-open');
        localStorage.setItem(storageKey, String(Date.now()));
        popupShown = true;
      }

      function triggerAutoPopup() {
        if (popupShown) return;
        var hasFeedback = document.body.dataset.salesSuccess === '1' || document.body.dataset.salesError === '1';
        if (hasFeedback) return;
        if (!canShowPopup()) return;
        popupShown = true;
        openModal();
      }

      // Exit-intent: mouse leaves viewport por cima
      document.addEventListener('mouseout', function (e) {
        if (e.clientY <= 0 && !popupShown) triggerAutoPopup();
      });

      // Scroll 60%: se scrollou 60% da página
      window.addEventListener('scroll', function () {
        if (popupShown) return;
        var scrollPct = window.scrollY / (document.body.scrollHeight - window.innerHeight);
        if (scrollPct >= 0.6) triggerAutoPopup();
      }, { passive: true });

      // Fallback: 25 segundos
      setTimeout(function () { if (!popupShown) triggerAutoPopup(); }, 25000);

      openButtons.forEach(function (button) {
        button.addEventListener('click', function (event) {
          event.preventDefault();
          openModal();
        });
      });

      closeButtons.forEach(function (button) {
        button.addEventListener('click', closeModal);
      });

      if (modal) {
        modal.addEventListener('click', function (event) {
          if (event.target === modal) closeModal();
        });
      }

      document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape' && modal && !modal.hidden) closeModal();
      });
    });
  </script>
