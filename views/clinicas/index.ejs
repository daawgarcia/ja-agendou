<%- include('../partials/header', { title: 'Clínicas' }) %>
<%- include('../partials/sidebar', { currentPage: 'clinicas' }) %>

<main class="content">
  <%- include('../partials/topbar', { pageTitle: 'Clínicas', subtitle: 'Área exclusiva do super admin para gerenciar clientes.' }) %>

  <section class="card form-card">
    <h3><%= editClinica ? 'Editar clínica' : 'Nova clínica' %></h3>

    <form method="POST" action="<%= editClinica ? '/clinicas/' + editClinica.id + '?_method=PUT' : '/clinicas' %>" class="grid-form grid-2">

      <div>
        <label>Nome</label>
        <input type="text" name="nome" value="<%= editClinica?.nome || '' %>" required />
      </div>

      <div>
        <label>Slug</label>
        <input type="text" name="slug" value="<%= editClinica?.slug || '' %>" placeholder="clinica-exemplo" required />
      </div>

      <div>
        <label>E-mail (login)</label>
        <input type="email" name="email" value="<%= editClinica?.email || '' %>" required />
      </div>

      <div>
        <label>Telefone</label>
        <input type="text" name="telefone" value="<%= editClinica?.telefone || '' %>" />
      </div>

      <% if (!editClinica) { %>
      <div>
        <label>Senha inicial</label>
        <input type="password" name="senha" placeholder="Senha do administrador" required />
      </div>
      <% } %>

      <div>
        <label>Status</label>
        <select name="status">
          <option value="ativo" <%= editClinica?.status === 'ativo' ? 'selected' : '' %>>ativo</option>
          <option value="pendente" <%= editClinica?.status === 'pendente' ? 'selected' : '' %>>pendente</option>
          <option value="inativo" <%= editClinica?.status === 'inativo' ? 'selected' : '' %>>inativo</option>
        </select>
      </div>

      <div class="form-actions full-width">
        <button type="submit" class="btn">
          <%= editClinica ? 'Atualizar clínica' : 'Salvar clínica' %>
        </button>

        <% if (editClinica) { %>
          <a href="/clinicas" class="btn btn-outline">Cancelar</a>
        <% } %>
      </div>

    </form>
  </section>

  <section class="card">
    <h3>Lista de clínicas</h3>

    <table>
      <thead>
        <tr>
          <th>Nome</th>
          <th>Slug</th>
          <th>E-mail</th>
          <th>Telefone</th>
          <th>Status</th>
          <th>Validade</th>
          <th>Último acesso</th>
          <th>Criada em</th>
          <th>Ações</th>
        </tr>
      </thead>

      <tbody>
        <% if (!clinicas.length) { %>
          <tr>
            <td colspan="9">Nenhuma clínica cadastrada.</td>
          </tr>
        <% } %>

        <% clinicas.forEach(clinica => { %>
          <tr>
            <td><%= clinica.nome %></td>
            <td><%= clinica.slug %></td>
            <td><%= clinica.email || '-' %></td>
            <td><%= clinica.telefone || '-' %></td>
            <td>
              <span class="badge badge-<%= clinica.status %>">
                <%= clinica.status %>
              </span>
            </td>
            <td>
              <% if (clinica.licenca_fim_em) { %>
                <div>Expira em <%= new Date(clinica.licenca_fim_em).toLocaleDateString('pt-BR') %></div>
                <small><%= clinica.licenca_dias || '-' %> dias</small>
              <% } else if (clinica.trial_fim_em) { %>
                <div>Trial ate <%= new Date(clinica.trial_fim_em).toLocaleDateString('pt-BR') %></div>
                <small>3 dias iniciais</small>
              <% } else { %>
                -
              <% } %>
            </td>
            <td>
              <% if (clinica.ultimo_acesso_em) { %>
                <div><%= new Date(clinica.ultimo_acesso_em).toLocaleDateString('pt-BR') %></div>
                <small><%= new Date(clinica.ultimo_acesso_em).toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' }) %></small>
              <% } else { %>
                -
              <% } %>
            </td>
            <td><%= clinica.created_at_formatado %></td>
            <td>
              <a href="/clinicas/<%= clinica.id %>/editar" class="btn btn-outline btn-small">
                Editar
              </a>

              <% if (clinica.status === 'pendente') { %>
                <form method="POST" action="/clinicas/<%= clinica.id %>/aprovar" style="display:inline-block; margin-left: 6px;">
                  <button type="submit" class="btn btn-green btn-small">Aprovar pedido</button>
                </form>
              <% } %>

              <% if (clinica.status === 'inativo' && !clinica.desbloqueado_em) { %>
                <form method="POST" action="/clinicas/<%= clinica.id %>/desbloquear" style="display:inline-block; margin-left: 6px;">
                  <button type="submit" class="btn btn-green btn-small">Desbloquear</button>
                </form>
              <% } %>

              <form method="POST" action="/clinicas/<%= clinica.id %>/licenca" style="display:inline-flex; gap:6px; align-items:center; margin-left:6px; margin-top:6px;">
                <input
                  type="number"
                  name="licenca_dias"
                  min="1"
                  value="<%= clinica.licenca_dias || 30 %>"
                  style="width:80px; padding:4px 6px;"
                  required
                />
                <button type="submit" class="btn btn-outline btn-small">Definir dias</button>
              </form>

              <% if (Number(user && user.clinica_id) !== Number(clinica.id)) { %>
                <form
                  method="POST"
                  action="/clinicas/<%= clinica.id %>/excluir"
                  style="display:inline-block; margin-left:6px; margin-top:6px;"
                  onsubmit="return confirm('Deseja realmente excluir este cliente? Esta ação remove dados da clínica.');"
                >
                  <button type="submit" class="btn btn-red btn-small">Excluir cliente</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>

    </table>
  </section>

</main>

</body>
</html>
