<%- include('../partials/header', { title: 'Relatórios' }) %>
<%- include('../partials/sidebar', { currentPage: 'relatorios' }) %>
<main class="content">
  <%- include('../partials/topbar', { pageTitle: 'Relatórios', subtitle: 'Exporte agenda, visão financeira e produtividade por dentista.' }) %>
  <div class="page-body">

    <!-- FILTER BAR -->
    <form method="GET" action="/relatorios" class="filter-bar">
      <div>
        <label>Mês</label>
        <input type="month" name="mes" value="<%= mesAno || '' %>" required />
      </div>
      <div>
        <label>Dentista</label>
        <select name="dentista_id">
          <option value="">Todos</option>
          <% (dentistas||[]).forEach(function(d){ %>
            <option value="<%= d.id %>" <%= String(dentistaId||'')=== String(d.id)?'selected':'' %>><%= d.nome %></option>
          <% }) %>
        </select>
      </div>
      <button type="submit" class="btn btn-sm">Filtrar</button>
    </form>

    <!-- KPI SUMMARY -->
    <div class="kpi-row">
      <div class="kpi-card">
        <span>Recebido no período</span>
        <strong>R$ <%= Number(stats?.receitaMes||0).toLocaleString('pt-BR',{minimumFractionDigits:2}) %></strong>
      </div>
      <div class="kpi-card">
        <span>Agendados</span>
        <strong><%= Number(stats?.agendados||0) %></strong>
      </div>
      <div class="kpi-card">
        <span>Cancelados</span>
        <strong><%= Number(stats?.cancelados||0) %></strong>
      </div>
      <div class="kpi-card">
        <span>Mês</span>
        <strong style="font-size:16px"><%= mesAno || '--' %></strong>
      </div>
    </div>

    <!-- TABLE BY DENTIST -->
    <div class="card">
      <h3>Resumo por dentista</h3>
      <table>
        <thead>
          <tr>
            <th>Dentista</th>
            <th>Atendidos</th>
            <th>Valor estimado</th>
            <th>Mês</th>
          </tr>
        </thead>
        <tbody>
          <% if(!(porDentista||[]).length){ %>
            <tr><td colspan="4" style="text-align:center;color:#9ca3af;padding:20px">Nenhum resultado. Aplique um filtro de período.</td></tr>
          <% } %>
          <% (porDentista||[]).forEach(function(l){ %>
            <tr>
              <td><%= l.dentista_nome||'-' %></td>
              <td><%= Number(l.total_atendidos||0) %></td>
              <td>R$ <%= Number(l.valor_total||0).toLocaleString('pt-BR',{minimumFractionDigits:2}) %></td>
              <td><%= mesAno || '-' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  </div>
</main>
</body>
</html>
