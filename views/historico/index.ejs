<%- include('../partials/header', { title: 'Histórico' }) %>
<%- include('../partials/sidebar', { currentPage: 'historico' }) %>
<main class="content">
  <%- include('../partials/topbar', { pageTitle: 'Histórico', subtitle: 'Registro dos atendimentos clínicos e observações.' }) %>
  <div class="page-body">
    <div class="two-col">
      <div>
        <div class="card">
          <h3>Novo registro</h3>
          <form method="POST" action="/historico" class="form-grid">
            <div class="full">
              <label>Paciente</label>
              <select name="paciente_id" required>
                <option value="">Selecione</option>
                <% pacientes.forEach(function(p){ %>
                  <option value="<%= p.id %>"><%= p.nome %></option>
                <% }) %>
              </select>
            </div>
            <div>
              <label>Data</label>
              <input type="date" name="data_evento" value="<%= new Date().toISOString().slice(0,10) %>" required />
            </div>
            <div>
              <label>Tipo</label>
              <input type="text" name="tipo_evento" placeholder="Ex.: Retorno, limpeza" />
            </div>
            <div>
              <label>Dentista</label>
              <input type="text" name="profissional" />
            </div>
            <div>
              <label>Status</label>
              <input type="text" name="status_historico" placeholder="Ex.: Concluído" />
            </div>
            <div class="full">
              <label>Descrição</label>
              <textarea name="descricao" rows="4"></textarea>
            </div>
            <div class="form-actions full">
              <button type="submit" class="btn">Salvar histórico</button>
            </div>
          </form>
        </div>
      </div>

      <div>
        <div class="card">
          <h3>Últimos registros</h3>
          <% if(!itens||!itens.length){ %>
            <div class="empty-state"><p>Nenhum registro encontrado.</p></div>
          <% } %>
          <table>
            <thead>
              <tr><th>Data</th><th>Paciente</th><th>Tipo</th><th>Status</th><th></th></tr>
            </thead>
            <tbody>
              <% (itens||[]).forEach(function(h){ %>
                <tr>
                  <td><%= h.data_evento %></td>
                  <td><%= h.paciente_nome %></td>
                  <td><%= h.tipo_evento||'-' %></td>
                  <td><%= h.status_historico||'-' %></td>
                  <td>
                    <form method="POST" action="/historico/<%= h.id %>?_method=DELETE" onsubmit="return confirm('Excluir registro?');">
                      <button type="submit" class="btn btn-red btn-sm">Excluir</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</main>
</body>
</html>
