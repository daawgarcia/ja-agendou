<%- include('../partials/header', { title: 'Agenda' }) %>
<%- include('../partials/sidebar', { currentPage: 'agenda' }) %>
<main class="content">
  <%- include('../partials/topbar', { pageTitle: 'Agenda', subtitle: 'Controle de consultas, envio de e-mail, fechamento de agenda por dentista e busca rápida por paciente.' }) %>

  <div class="page-body">
    <% var clinicaNome = String((user && user.clinica_nome) || 'sua clínica'); %>
    <%
      var agendaItems = agendamentos || [];
      var hojeISO = new Date().toISOString().slice(0,10);
      var now = new Date();
      var nowMinutes = now.getHours() * 60 + now.getMinutes();
      function horaToMinutes(h){
        if (!h || h.indexOf(':') < 0) return null;
        var parts = h.split(':');
        return Number(parts[0]) * 60 + Number(parts[1]);
      }

      var agendaHoje = agendaItems
        .filter(function(a){ return a.data === hojeISO; })
        .sort(function(a,b){ return String(a.hora_inicio || '').localeCompare(String(b.hora_inicio || '')); });

      var totalHoje = agendaHoje.filter(function(a){ return a.status !== 'cancelado'; }).length;
      var confirmaveisHoje = agendaHoje.filter(function(a){ return a.status === 'agendado' || a.status === 'confirmado'; });
      var totalConfirmaveisHoje = confirmaveisHoje.length;
      var totalConfirmadosHoje = confirmaveisHoje.filter(function(a){ return a.status === 'confirmado'; }).length;
      var pendentesConfirmacaoHoje = confirmaveisHoje.filter(function(a){ return a.status === 'agendado'; }).length;
      var taxaConfirmacaoHoje = totalConfirmaveisHoje ? Math.round((totalConfirmadosHoje / totalConfirmaveisHoje) * 100) : 0;

      var riscoFaltaHoje = confirmaveisHoje.filter(function(a){
        if (a.status !== 'agendado') return false;
        var inicioMin = horaToMinutes(a.hora_inicio);
        if (inicioMin === null) return false;
        var delta = inicioMin - nowMinutes;
        return delta <= 120;
      }).length;

      var filaConfirmacaoHoje = agendaHoje
        .filter(function(a){ return ['agendado','confirmado'].indexOf(a.status) >= 0; })
        .map(function(a){
          var inicioMin = horaToMinutes(a.hora_inicio);
          var delta = inicioMin === null ? null : inicioMin - nowMinutes;
          var nivel = 'ok';
          if (a.status === 'agendado' && delta !== null && delta <= 120) nivel = 'risco';
          if (a.status === 'agendado' && delta !== null && delta > 120) nivel = 'pendente';
          if (a.status === 'confirmado') nivel = 'confirmado';
          return {
            id: a.id,
            data_formatada: a.data_formatada,
            hora_inicio: a.hora_inicio,
            hora_fim: a.hora_fim,
            paciente_nome: a.paciente_nome,
            dentista_nome: a.dentista_nome,
            telefone: a.telefone,
            status: a.status,
            nivel: nivel,
          };
        });
    %>

    <% if (locals.flash) { %>
      <div class="alert alert-<%= flash.type %>"><%= flash.msg %></div>
    <% } %>

    <section class="agenda-hero">
      <div class="agenda-hero-head">
        <div>
          <h2>Painel da agenda</h2>
          <p>Visão rápida do dia e da carteira ativa para tomada de decisão da recepção.</p>
        </div>
        <div class="agenda-status-legend" aria-label="Legenda de status">
          <span class="badge badge-status-agendado">Agendado</span>
          <span class="badge badge-status-confirmado">Confirmado</span>
          <span class="badge badge-status-concluido">Concluído</span>
          <span class="badge badge-status-falta">Falta</span>
          <span class="badge badge-status-cancelado">Cancelado</span>
        </div>
      </div>
      <div class="agenda-kpis">
        <article class="agenda-kpi-card">
          <span>Atendimentos de hoje</span>
          <strong><%= Number(totalHoje || 0) %></strong>
        </article>
        <article class="agenda-kpi-card">
          <span>Taxa de confirmação (hoje)</span>
          <strong><%= Number(taxaConfirmacaoHoje || 0) %>%</strong>
        </article>
        <article class="agenda-kpi-card">
          <span>Pendentes de confirmação</span>
          <strong><%= Number(pendentesConfirmacaoHoje || 0) %></strong>
        </article>
        <article class="agenda-kpi-card agenda-kpi-risk">
          <span>Risco de falta (até 2h)</span>
          <strong><%= Number(riscoFaltaHoje || 0) %></strong>
        </article>
      </div>
    </section>

    <div class="two-col">

      <!-- FORM NOVO AGENDAMENTO -->
      <div>
        <div class="card">
          <h3><%= editAgendamento ? 'Editar agendamento' : 'Novo agendamento' %></h3>
          <form method="POST" action="<%= editAgendamento ? '/agendamentos/' + editAgendamento.id + '?_method=PUT' : '/agendamentos' %>" class="form-grid">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

            <div class="full">
              <label>Paciente</label>
              <div class="autocomplete-wrapper">
                <input type="text" id="paciente-search" placeholder="Digite o nome ou telefone do paciente" autocomplete="off"
                       value="<%= editAgendamento && editAgendamento.paciente_nome ? editAgendamento.paciente_nome : '' %>" />
                <input type="hidden" name="paciente_id" id="paciente-id" value="<%= editAgendamento?.paciente_id || '' %>" required />
                <ul class="autocomplete-list" id="autocomplete-list" style="display:none"></ul>
                <p class="autocomplete-hint">Digite o nome do paciente para pesquisar e selecione uma opção da lista.</p>
              </div>
            </div>

            <div>
              <label>Data</label>
              <input type="date" name="data" value="<%= editAgendamento?.data || '' %>" required />
            </div>
            <div>
              <label>Hora inicial</label>
              <input type="time" name="hora_inicio" value="<%= editAgendamento?.hora_inicio || '' %>" required />
            </div>
            <div>
              <label>Hora final</label>
              <input type="time" name="hora_fim" value="<%= editAgendamento?.hora_fim || '' %>" required />
            </div>
            <div>
              <label>Serviço</label>
              <select name="servico_id" id="servico_id">
                <option value="">Selecione o serviço</option>
                <% (servicos||[]).forEach(function(s){ %>
                  <option value="<%= s.id %>" data-valor="<%= s.valor_padrao||0 %>"
                    <%= editAgendamento && Number(editAgendamento.servico_id)===Number(s.id)?'selected':'' %>><%= s.nome %></option>
                <% }) %>
              </select>
            </div>
            <div>
              <label>Status</label>
              <select name="status">
                <% ['agendado','confirmado','concluido','cancelado','falta'].forEach(function(st){ %>
                  <option value="<%= st %>" <%= editAgendamento?.status===st?'selected':'' %>><%= st.charAt(0).toUpperCase()+st.slice(1) %></option>
                <% }) %>
              </select>
            </div>
            <div class="full">
              <label>Procedimento / descrição</label>
              <input type="text" name="procedimento" value="<%= editAgendamento?.procedimento||'' %>" />
            </div>
            <div>
              <label>Dentista responsável</label>
              <select name="dentista_id" id="dentista_sel">
                <option value="">Selecione o dentista</option>
                <% (dentistas||[]).forEach(function(d){ %>
                  <option value="<%= d.id %>" data-email="<%= d.email||'' %>"
                    <%= editAgendamento && Number(editAgendamento.dentista_id)===Number(d.id)?'selected':'' %>><%= d.nome %></option>
                <% }) %>
              </select>
            </div>
            <div>
              <label>E-mail do dentista</label>
              <input type="email" name="dentista_email" id="dentista_email" value="<%= editAgendamento?.dentista_email||'' %>" />
            </div>
            <div>
              <label>Valor estimado (R$)</label>
              <input type="number" step="0.01" min="0" name="valor_estimado" id="valor_estimado" value="<%= editAgendamento?.valor_estimado||'' %>" />
            </div>
            <div class="full">
              <label>Observações</label>
              <textarea name="observacoes" rows="3"><%= editAgendamento?.observacoes||'' %></textarea>
            </div>

            <div class="form-actions full">
              <button type="submit" class="btn"><%= editAgendamento ? 'Atualizar agendamento' : 'Salvar agendamento' %></button>
              <button type="button" class="btn btn-outline" onclick="document.querySelector('form').reset();document.getElementById('paciente-id').value='';document.getElementById('paciente-search').value='';">Limpar</button>
            </div>
          </form>

          <div class="agenda-note">
            Ao criar um novo agendamento, o sistema enviará automaticamente a confirmação por e-mail para o paciente, quando houver e-mail cadastrado.
          </div>
        </div>
      </div>

      <!-- RIGHT PANEL -->
      <div>
        <!-- FECHAR AGENDA -->
        <div class="card">
          <h3>Fechar agenda do dentista</h3>
          <form method="POST" action="/dentistas/fechamentos" class="form-grid">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div>
              <label>Dentista</label>
              <select name="dentista_id" required>
                <option value="">Selecione o dentista</option>
                <% (dentistas||[]).forEach(function(d){ %>
                  <option value="<%= d.id %>"><%= d.nome %></option>
                <% }) %>
              </select>
            </div>
            <div>
              <label>Data</label>
              <input type="date" name="data_fechamento" value="<%= new Date().toISOString().slice(0,10) %>" required />
            </div>
            <div class="form-actions full">
              <button class="btn btn-sm" type="submit">Fechar agenda</button>
            </div>
          </form>
          <p class="agenda-help-text">Agenda fechada bloqueia novos agendamentos e também a edição dos agendamentos existentes daquele dentista na data escolhida.</p>
        </div>

        <!-- ENVIAR AGENDA POR EMAIL -->
        <div class="card">
          <h3>Enviar agenda do dia para o dentista</h3>
          <form method="POST" action="/agendamentos/lembretes/email-agenda" class="form-grid">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div>
              <label>Data da agenda</label>
              <input type="date" name="data" value="<%= new Date().toISOString().slice(0,10) %>" />
            </div>
            <div>
              <label>Dentista</label>
              <select name="dentista_id" id="email-dentista-sel">
                <option value="">Selecionar dentista</option>
                <% (dentistas||[]).forEach(function(d){ %>
                  <option value="<%= d.id %>" data-email="<%= d.email||'' %>"><%= d.nome %></option>
                <% }) %>
              </select>
            </div>
            <div>
              <label>Nome do dentista</label>
              <input type="text" id="email-dentista-nome" name="_nome_display" readonly />
            </div>
            <div>
              <label>E-mail do dentista</label>
              <input type="email" id="email-dentista-email" name="email_override" />
            </div>
            <input type="hidden" name="periodo" value="dia" />
            <div class="form-actions full">
              <button type="submit" class="btn btn-sm">Enviar agenda do dia</button>
            </div>
          </form>
        </div>
      </div>

    </div><!-- end two-col -->

    <section class="card agenda-queue-card">
      <div class="agenda-queue-head">
        <div>
          <h3>Fila de confirmação do dia</h3>
          <p>Priorize contatos de pacientes sem confirmação próxima do horário.</p>
        </div>
        <a href="/agendamentos/lembretes" class="btn btn-outline btn-sm">Abrir central de lembretes</a>
      </div>

      <% if (!filaConfirmacaoHoje.length) { %>
        <div class="agenda-empty-state">Nenhum agendamento agendado/confirmado para hoje.</div>
      <% } else { %>
        <div class="agenda-queue-list">
          <% filaConfirmacaoHoje.forEach(function(item){ %>
            <%
              var _tel=(item.telefone||'').replace(/\D/g,'');
              if(_tel.length===10||_tel.length===11) _tel='55'+_tel;
              var _msg=encodeURIComponent('Olá '+item.paciente_nome+', confirmando seu agendamento hoje ('+item.data_formatada+') às '+item.hora_inicio+'. Pode nos responder com um OK? - '+clinicaNome);
            %>
            <article class="agenda-queue-item <%= item.nivel === 'risco' ? 'is-risk' : (item.nivel === 'confirmado' ? 'is-confirmed' : '') %>">
              <div class="agenda-queue-main">
                <div class="agenda-queue-time"><%= item.hora_inicio %> - <%= item.hora_fim %></div>
                <div class="agenda-queue-patient"><%= item.paciente_nome %></div>
                <div class="agenda-queue-meta">Dentista: <%= item.dentista_nome || 'A definir' %></div>
              </div>
              <div class="agenda-queue-state">
                <% if (item.nivel === 'risco') { %>
                  <span class="badge badge-status-falta">Risco de falta</span>
                <% } else if (item.nivel === 'confirmado') { %>
                  <span class="badge badge-status-confirmado">Confirmado</span>
                <% } else { %>
                  <span class="badge badge-status-agendado">Pendente</span>
                <% } %>
              </div>
              <div class="agenda-queue-actions">
                <% if(_tel.length>=12){ %>
                  <a href="https://wa.me/<%= _tel %>?text=<%= _msg %>" target="_blank" class="btn btn-whatsapp btn-sm">WhatsApp</a>
                <% } %>
                <a href="/agendamentos/<%= item.id %>/editar" class="btn btn-outline btn-sm">Editar</a>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>

    <!-- TABS -->
    <div class="agenda-tabs-bar">
      <button class="agenda-tab active" data-tab="lista" onclick="switchTab('lista')">Lista</button>
      <button class="agenda-tab" data-tab="semana" onclick="switchTab('semana')">Semana</button>
      <button class="agenda-tab" data-tab="mes" onclick="switchTab('mes')">Mês</button>
    </div>

    <!-- TAB: LISTA -->
    <div class="agenda-panel active" id="panel-lista">
    <!-- AGENDAMENTOS ATIVOS -->
    <div class="card">
      <div class="agenda-list-header">
        <div class="agenda-list-title">
          <h3>Agendamentos ativos</h3>
          <p>Pesquise pelo nome do paciente, telefone ou dentista.</p>
        </div>
        <form method="GET" action="/agendamentos" class="agenda-search-form">
          <input type="text" name="busca" value="<%= locals.busca||'' %>" placeholder="Paciente, telefone ou dentista" class="agenda-search-input" />
          <button type="submit" class="btn btn-sm">Pesquisar</button>
        </form>
      </div>

      <table class="agenda-table">
        <thead>
          <tr>
            <th>Data</th>
            <th>Horário</th>
            <th>Paciente</th>
            <th>Dentista</th>
            <th>Status</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if(!agendamentos.length){ %>
            <tr><td colspan="6" class="agenda-empty-cell">Nenhum agendamento encontrado.</td></tr>
          <% } %>
          <% agendamentos.forEach(function(item){ %>
            <tr class="row-<%= item.status %>">
              <td><%= item.data_formatada %></td>
              <td><%= item.hora_inicio %>h às <%= item.hora_fim %>h</td>
              <td><%= item.paciente_nome %></td>
              <td><%= item.dentista_nome||'-' %></td>
              <td>
                <% var statusLabel = item.status.charAt(0).toUpperCase()+item.status.slice(1); %>
                <% var statusClass = 'badge-status-cancelado'; %>
                <% if (item.status === 'agendado') statusClass = 'badge-status-agendado'; %>
                <% if (item.status === 'confirmado') statusClass = 'badge-status-confirmado'; %>
                <% if (item.status === 'concluido' || item.status === 'atendido') statusClass = 'badge-status-concluido'; %>
                <% if (item.status === 'falta') statusClass = 'badge-status-falta'; %>
                <span class="badge <%= statusClass %>"><%= statusLabel %></span>
              </td>
              <td>
                <div class="agenda-row-actions">
                  <a href="/agendamentos/<%= item.id %>/editar" class="btn btn-outline btn-sm">Editar</a>
                  <%
                    var _tel=(item.telefone||'').replace(/\D/g,'');
                    if(_tel.length===10||_tel.length===11) _tel='55'+_tel;
                    var _msg=encodeURIComponent('Olá '+item.paciente_nome+', lembrando do seu agendamento em '+item.data_formatada+' às '+item.hora_inicio+'. Em caso de imprevisto, nos avise. - '+clinicaNome);
                  %>
                  <% if(_tel.length>=12){ %>
                    <a href="https://wa.me/<%= _tel %>?text=<%= _msg %>" target="_blank" class="btn btn-whatsapp btn-sm">WhatsApp</a>
                  <% } %>
                  <form method="POST" action="/agendamentos/<%= item.id %>?_method=DELETE" onsubmit="return confirm('Cancelar agendamento?');">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button type="submit" class="btn btn-red btn-sm">Cancelar</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    </div><!-- end panel-lista -->

    <!-- TAB: SEMANA -->
    <div class="agenda-panel" id="panel-semana">
      <div class="card">
        <div class="cal-nav">
          <div class="cal-nav-group">
            <button onclick="navWeek(-1)">&larr; Anterior</button>
            <button type="button" class="cal-btn-light" onclick="goCurrentWeek()">Hoje</button>
          </div>
          <span id="weekLabel"></span>
          <div class="cal-nav-group">
            <button onclick="navWeek(1)">Próxima &rarr;</button>
          </div>
        </div>
        <div class="agenda-calendar-scroll">
          <table class="cal-week" id="weekGrid"></table>
        </div>
      </div>
    </div>

    <!-- TAB: MÊS -->
    <div class="agenda-panel" id="panel-mes">
      <div class="card">
        <div class="cal-nav">
          <div class="cal-nav-group">
            <button onclick="navMonth(-1)">&larr; Anterior</button>
            <button type="button" class="cal-btn-light" onclick="goCurrentMonth()">Hoje</button>
          </div>
          <span id="monthLabel"></span>
          <div class="cal-nav-group">
            <button onclick="navMonth(1)">Próximo &rarr;</button>
          </div>
        </div>
        <table class="cal-month" id="monthGrid"></table>
      </div>
    </div>

  </div>
</main>
<script>
(function(){
  // Serviço auto-fill valor
  var sel=document.getElementById('servico_id'),val=document.getElementById('valor_estimado');
  if(sel&&val){ sel.addEventListener('change',function(){ if(val.value) return; var o=sel.options[sel.selectedIndex]; var v=o?o.getAttribute('data-valor'):''; if(v) val.value=Number(v).toFixed(2); }); }

  // Dentista auto-fill email
  var dsel=document.getElementById('dentista_sel'),demail=document.getElementById('dentista_email');
  if(dsel&&demail){ dsel.addEventListener('change',function(){ var o=dsel.options[dsel.selectedIndex]; demail.value=o?o.getAttribute('data-email')||'':''; }); }

  // Email agenda dentist fill
  var esel=document.getElementById('email-dentista-sel');
  if(esel){
    esel.addEventListener('change',function(){
      var o=esel.options[esel.selectedIndex];
      var nome=document.getElementById('email-dentista-nome');
      var email=document.getElementById('email-dentista-email');
      if(nome) nome.value=o?o.text:'';
      if(email) email.value=o?o.getAttribute('data-email')||'':'';
    });
  }

  // Autocomplete paciente
  var inp=document.getElementById('paciente-search'),hid=document.getElementById('paciente-id'),ul=document.getElementById('autocomplete-list');
  var pacientes=<%- JSON.stringify((pacientes||[]).map(function(p){return{id:p.id,nome:p.nome,tel:p.telefone||''}})) %>;
  if(inp){
    inp.addEventListener('input',function(){
      var q=this.value.toLowerCase().trim();
      ul.innerHTML='';ul.style.display='none';
      if(!q||q.length<2) return;
      var filtered=pacientes.filter(function(p){ return p.nome.toLowerCase().includes(q)||(p.tel&&p.tel.includes(q)); }).slice(0,8);
      if(!filtered.length) return;
      filtered.forEach(function(p){
        var li=document.createElement('li');
        li.textContent=p.nome+(p.tel?' ('+p.tel+')':'');
        li.addEventListener('click',function(){ inp.value=p.nome; hid.value=p.id; ul.style.display='none'; });
        ul.appendChild(li);
      });
      ul.style.display='block';
    });
    document.addEventListener('click',function(e){ if(e.target!==inp) ul.style.display='none'; });
  }

  // ========== CALENDAR DATA ==========
  var calData=<%- JSON.stringify((agendamentos||[]).map(function(a){return{id:a.id,data:a.data,hi:a.hora_inicio,hf:a.hora_fim,pac:a.paciente_nome,den:a.dentista_nome||'',st:a.status}})) %>;
  var HOURS_START=7,HOURS_END=20;
  var DIAS=['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];
  var MESES=['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];

  // Current calendar state
  var curWeekStart=mondayOf(new Date());
  var curMonth=new Date().getMonth();
  var curYear=new Date().getFullYear();

  function mondayOf(d){var dt=new Date(d);var day=dt.getDay();var diff=day===0?-6:1-day;dt.setDate(dt.getDate()+diff);dt.setHours(0,0,0,0);return dt;}
  function fmtISO(d){return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');}
  function fmtBR(d){return String(d.getDate()).padStart(2,'0')+'/'+String(d.getMonth()+1).padStart(2,'0');}
  function todayISO(){return fmtISO(new Date());}

  // ========== TABS ==========
  window.switchTab=function(tab){
    document.querySelectorAll('.agenda-tab').forEach(function(b){b.classList.toggle('active',b.dataset.tab===tab);});
    document.querySelectorAll('.agenda-panel').forEach(function(p){p.classList.toggle('active',p.id==='panel-'+tab);});
    if(tab==='semana') renderWeek();
    if(tab==='mes') renderMonth();
  };

  // ========== PRE-FILL FORM ==========
  function prefillForm(dateISO,hour){
    var f=document.querySelector('form[action="/agendamentos"]')||document.querySelector('form[action^="/agendamentos"]');
    if(!f) return;
    var di=f.querySelector('[name="data"]');if(di)di.value=dateISO;
    var hi=f.querySelector('[name="hora_inicio"]');if(hi)hi.value=String(hour).padStart(2,'0')+':00';
    var hf=f.querySelector('[name="hora_fim"]');if(hf)hf.value=String(hour+1).padStart(2,'0')+':00';
    f.scrollIntoView({behavior:'smooth',block:'start'});
  }

  // ========== WEEKLY VIEW ==========
  function eventsForDate(iso){return calData.filter(function(e){return e.data===iso;});}

  function renderWeek(){
    var grid=document.getElementById('weekGrid');
    var label=document.getElementById('weekLabel');
    var days=[];
    for(var i=0;i<7;i++){var d=new Date(curWeekStart);d.setDate(d.getDate()+i);days.push(d);}
    label.textContent=fmtBR(days[0])+' - '+fmtBR(days[6])+'/'+days[6].getFullYear();

    var html='<thead><tr><th></th>';
    days.forEach(function(d){html+='<th>'+DIAS[d.getDay()]+'<br>'+fmtBR(d)+'</th>';});
    html+='</tr></thead><tbody>';

    for(var h=HOURS_START;h<HOURS_END;h++){
      html+='<tr>';
      html+='<td class="cal-hour">'+String(h).padStart(2,'0')+':00</td>';
      days.forEach(function(d){
        var iso=fmtISO(d);
        var evts=eventsForDate(iso).filter(function(e){
          var eh=parseInt(e.hi.split(':')[0],10);
          return eh===h;
        });
        if(evts.length){
          html+='<td>';
          evts.forEach(function(e){
            html+='<div class="cal-evt cal-evt-'+e.st+'" title="'+e.pac+' ('+e.den+') '+e.hi+'-'+e.hf+'" onclick="window.location=\'/agendamentos/'+e.id+'/editar\'">'+e.hi+' '+e.pac+'</div>';
          });
          html+='</td>';
        } else {
          html+='<td onclick="prefillForm(\''+iso+'\','+h+')" title="Clique para agendar às '+String(h).padStart(2,'0')+':00"></td>';
        }
      });
      html+='</tr>';
    }
    html+='</tbody>';
    grid.innerHTML=html;
  }

  window.navWeek=function(dir){
    curWeekStart=new Date(curWeekStart);
    curWeekStart.setDate(curWeekStart.getDate()+dir*7);
    renderWeek();
  };

  window.goCurrentWeek=function(){
    curWeekStart=mondayOf(new Date());
    renderWeek();
  };

  // ========== MONTHLY VIEW ==========
  function renderMonth(){
    var grid=document.getElementById('monthGrid');
    var label=document.getElementById('monthLabel');
    label.textContent=MESES[curMonth]+' '+curYear;

    var firstDay=new Date(curYear,curMonth,1);
    var startOffset=firstDay.getDay();
    var daysInMonth=new Date(curYear,curMonth+1,0).getDate();
    var prevDays=new Date(curYear,curMonth,0).getDate();
    var today=todayISO();

    var html='<thead><tr>';
    DIAS.forEach(function(d){html+='<th>'+d+'</th>';});
    html+='</tr></thead><tbody><tr>';

    // Previous month padding
    for(var i=0;i<startOffset;i++){
      var pd=prevDays-startOffset+1+i;
      html+='<td class="outro-mes"><div class="dia-num">'+pd+'</div></td>';
    }

    var col=startOffset;
    for(var day=1;day<=daysInMonth;day++){
      if(col>0&&col%7===0) html+='</tr><tr>';
      var iso=curYear+'-'+String(curMonth+1).padStart(2,'0')+'-'+String(day).padStart(2,'0');
      var evts=eventsForDate(iso);
      var isToday=iso===today;
      html+='<td class="'+(isToday?'dia-hoje':'')+'" onclick="goToWeek(\''+iso+'\')">';
      html+='<div class="dia-num">'+day+'</div>';
      if(evts.length){
        html+='<div class="cal-mini">';
        html+='<strong>'+evts.length+' agend.</strong><br>';
        evts.slice(0,3).forEach(function(e){
          html+='<span class="cal-evt cal-evt-'+e.st+' cal-mini-item">'+e.hi+' '+e.pac.split(' ')[0]+'</span>';
        });
        if(evts.length>3) html+='<span class="cal-more">+'+String(evts.length-3)+' mais</span>';
        html+='</div>';
      }
      html+='</td>';
      col++;
    }

    // Next month padding
    var remaining=(7-col%7)%7;
    for(var j=1;j<=remaining;j++){
      html+='<td class="outro-mes"><div class="dia-num">'+j+'</div></td>';
    }
    html+='</tr></tbody>';
    grid.innerHTML=html;
  }

  window.navMonth=function(dir){
    curMonth+=dir;
    if(curMonth>11){curMonth=0;curYear++;}
    if(curMonth<0){curMonth=11;curYear--;}
    renderMonth();
  };

  window.goCurrentMonth=function(){
    curMonth=new Date().getMonth();
    curYear=new Date().getFullYear();
    renderMonth();
  };

  window.goToWeek=function(iso){
    var parts=iso.split('-');
    var dt=new Date(Number(parts[0]),Number(parts[1])-1,Number(parts[2]));
    curWeekStart=mondayOf(dt);
    switchTab('semana');
  };
})();
</script>
</body>
</html>
