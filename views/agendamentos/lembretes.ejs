<%- include('../partials/header', { title: 'Lembretes WhatsApp' }) %>
<%- include('../partials/sidebar') %>
<%
  var clinicaNome = String((user && user.clinica_nome) || 'sua clínica');

  function phoneToWhatsapp(rawPhone) {
    var phone = String(rawPhone || '').replace(/\D/g, '');
    if (phone.length === 10 || phone.length === 11) {
      phone = '55' + phone;
    }
    return phone.length >= 12 ? phone : '';
  }

  function buildReminderMessage(item) {
    return encodeURIComponent('Olá ' + item.paciente_nome + ', lembrando do seu agendamento de ' + item.data_formatada + ' às ' + item.hora_inicio + '. Em caso de imprevisto, nos avise. - ' + clinicaNome);
  }
%>
<main class="content">
  <%- include('../partials/topbar', { pageTitle: 'Lembretes WhatsApp', subtitle: 'Controle diário dos avisos enviados aos pacientes.' }) %>

  <% if (emailFeedback && emailFeedback.message) { %>
    <div class="alert <%= emailFeedback.status === 'erro' ? 'alert-error' : '' %>" style="margin-bottom: 18px;">
      <%= emailFeedback.message %>
    </div>
  <% } %>

  <% if (whatsappFeedback && whatsappFeedback.message) { %>
    <div class="alert <%= whatsappFeedback.status === 'erro' ? 'alert-error' : '' %>" style="margin-bottom: 18px;">
      <%= whatsappFeedback.message %>
    </div>
  <% } %>

  <section class="card">
    <div class="section-header">
      <h3>Disparo por e-mail da agenda</h3>
      <% if (!mailConfigured) { %>
        <span class="badge badge-cancelado">SMTP não configurado</span>
      <% } else { %>
        <span class="badge badge-concluido">SMTP ativo</span>
      <% } %>
    </div>
    <form method="POST" action="/agendamentos/lembretes/email-agenda" class="grid-form grid-4">
      <div>
        <label>Data base</label>
        <input type="date" name="data" value="<%= dataSelecionada %>" required />
      </div>
      <div>
        <label>Período</label>
        <select name="periodo">
          <option value="dia">Dia selecionado</option>
          <option value="semana">Semana da data</option>
        </select>
      </div>
      <div>
        <label>Dentista</label>
        <select name="dentista_id">
          <option value="">Todos os dentistas</option>
          <% (dentistas || []).forEach(function(d){ %>
            <option value="<%= d.id %>"><%= d.nome %> <%= d.email ? '(' + d.email + ')' : '(sem e-mail)' %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label>E-mail destino (opcional)</label>
        <input type="email" name="email_override" placeholder="Use quando o dentista estiver sem e-mail" />
      </div>
      <div class="form-actions" style="align-items:flex-end;">
        <button type="submit" class="btn" <%= !mailConfigured ? 'disabled' : '' %>>Enviar agenda por e-mail</button>
      </div>
    </form>
    <p class="muted-inline" style="margin-top:10px; display:block;">
      Este envio manda para os dentistas ativos com e-mail cadastrado. No novo agendamento, paciente e dentista também recebem e-mail automático.
    </p>
  </section>

  <section class="card">
    <div class="section-header">
      <h3>Disparo por WhatsApp</h3>
      <% if (!whatsappConfigured) { %>
        <span class="badge badge-cancelado">API nao configurada</span>
      <% } else { %>
        <span class="badge badge-concluido">API ativa</span>
      <% } %>
    </div>
    <p class="muted-inline" style="display:block; margin-top:4px;">
      O envio direto usa a WhatsApp Cloud API. Se a Meta bloquear texto livre fora da janela de atendimento, sera necessario trocar para template aprovado.
    </p>
  </section>

  <section class="cards cards-3">
    <div class="card stat-card">
      <span>Total do dia</span>
      <h2><%= Number(resumo.total || 0) %></h2>
    </div>
    <div class="card stat-card">
      <span>Pendentes</span>
      <h2><%= Number(resumo.pendentes || 0) %></h2>
    </div>
    <div class="card stat-card success-card">
      <span>Enviados</span>
      <h2><%= Number(resumo.enviados || 0) %></h2>
    </div>
  </section>

  <section class="card">
    <div class="section-header">
      <h3>Fila de lembretes</h3>
      <form method="GET" action="/agendamentos/lembretes" class="grid-form" style="display:flex; gap:8px; align-items:flex-end;">
        <div>
          <label>Data</label>
          <input type="date" name="data" value="<%= dataSelecionada %>" />
        </div>
        <button type="submit" class="btn btn-small">Atualizar</button>
      </form>
    </div>

    <table>
      <thead>
        <tr>
          <th>Horário</th>
          <th>Paciente</th>
          <th>Dentista</th>
          <th>Serviço</th>
          <th>Status</th>
          <th>Lembrete</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        <% if (!agendamentos.length) { %>
          <tr><td colspan="7">Nenhum agendamento elegível para lembrete nesta data.</td></tr>
        <% } %>
        <% agendamentos.forEach(function(item) { %>
          <% var phone = phoneToWhatsapp(item.telefone); %>
          <tr>
            <td><strong><%= item.hora_inicio %></strong></td>
            <td><%= item.paciente_nome %></td>
            <td><%= item.dentista_nome %></td>
            <td><%= item.servico_nome %></td>
            <td><span class="badge badge-<%= item.status %>"><%= item.status %></span></td>
            <td>
              <% if (item.lembrete_enviado_em) { %>
                <span class="badge badge-concluido">Enviado</span>
                <div class="muted-inline" style="margin-top:4px; font-size:12px;"><%= item.lembrete_enviado_fmt %></div>
              <% } else { %>
                <span class="badge badge-agendado">Pendente</span>
              <% } %>
            </td>
            <td class="actions-cell">
              <form method="POST" action="/agendamentos/<%= item.id %>/lembrete-whatsapp">
                <button type="submit" class="btn btn-whatsapp btn-small" <%= !whatsappConfigured ? 'disabled' : '' %>>Enviar via API</button>
              </form>

              <% if (phone) { %>
                <a href="https://wa.me/<%= phone %>?text=<%= buildReminderMessage(item) %>" target="_blank" rel="noopener" class="btn btn-whatsapp btn-small">Abrir WhatsApp</a>
              <% } else { %>
                <span class="muted-inline">Sem telefone</span>
              <% } %>

              <% if (!item.lembrete_enviado_em) { %>
                <form method="POST" action="/agendamentos/<%= item.id %>/lembrete-enviado">
                  <button type="submit" class="btn btn-small">Marcar enviado</button>
                </form>
              <% } else { %>
                <form method="POST" action="/agendamentos/<%= item.id %>/lembrete-limpar" onsubmit="return confirm('Reabrir este lembrete como pendente?');">
                  <button type="submit" class="btn btn-outline btn-small">Reabrir</button>
                </form>
              <% } %>
              <a href="/agendamentos/<%= item.id %>/editar" class="btn btn-outline btn-small">Editar</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </section>
</main>
</body>
</html>
