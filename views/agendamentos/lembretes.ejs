<%- include('../partials/header', { title: 'Lembretes WhatsApp' }) %>
<%- include('../partials/sidebar') %>
<%
  function phoneToWhatsapp(rawPhone) {
    var phone = String(rawPhone || '').replace(/\D/g, '');
    if (phone.length === 10 || phone.length === 11) {
      phone = '55' + phone;
    }
    return phone.length >= 12 ? phone : '';
  }

  function buildReminderMessage(item) {
    return encodeURIComponent('Olá ' + item.paciente_nome + ', lembrando do seu agendamento de ' + item.data_formatada + ' às ' + item.hora_inicio + '. Em caso de imprevisto, nos avise. - Já Agendou');
  }
%>
<main class="content">
  <%- include('../partials/topbar', { pageTitle: 'Lembretes WhatsApp', subtitle: 'Controle diário dos avisos enviados aos pacientes.' }) %>

  <section class="cards cards-3">
    <div class="card stat-card">
      <span>Total do dia</span>
      <h2><%= Number(resumo.total || 0) %></h2>
    </div>
    <div class="card stat-card">
      <span>Pendentes</span>
      <h2><%= Number(resumo.pendentes || 0) %></h2>
    </div>
    <div class="card stat-card success-card">
      <span>Enviados</span>
      <h2><%= Number(resumo.enviados || 0) %></h2>
    </div>
  </section>

  <section class="card">
    <div class="section-header">
      <h3>Fila de lembretes</h3>
      <form method="GET" action="/agendamentos/lembretes" class="grid-form" style="display:flex; gap:8px; align-items:flex-end;">
        <div>
          <label>Data</label>
          <input type="date" name="data" value="<%= dataSelecionada %>" />
        </div>
        <button type="submit" class="btn btn-small">Atualizar</button>
      </form>
    </div>

    <table>
      <thead>
        <tr>
          <th>Horário</th>
          <th>Paciente</th>
          <th>Dentista</th>
          <th>Serviço</th>
          <th>Status</th>
          <th>Lembrete</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        <% if (!agendamentos.length) { %>
          <tr><td colspan="7">Nenhum agendamento elegível para lembrete nesta data.</td></tr>
        <% } %>
        <% agendamentos.forEach(function(item) { %>
          <% var phone = phoneToWhatsapp(item.telefone); %>
          <tr>
            <td><strong><%= item.hora_inicio %></strong></td>
            <td><%= item.paciente_nome %></td>
            <td><%= item.dentista_nome %></td>
            <td><%= item.servico_nome %></td>
            <td><span class="badge badge-<%= item.status %>"><%= item.status %></span></td>
            <td>
              <% if (item.lembrete_enviado_em) { %>
                <span class="badge badge-concluido">Enviado</span>
                <div class="muted-inline" style="margin-top:4px; font-size:12px;"><%= item.lembrete_enviado_fmt %></div>
              <% } else { %>
                <span class="badge badge-agendado">Pendente</span>
              <% } %>
            </td>
            <td class="actions-cell">
              <% if (phone) { %>
                <a href="https://wa.me/<%= phone %>?text=<%= buildReminderMessage(item) %>" target="_blank" rel="noopener" class="btn btn-whatsapp btn-small">Enviar</a>
              <% } else { %>
                <span class="muted-inline">Sem telefone</span>
              <% } %>

              <% if (!item.lembrete_enviado_em) { %>
                <form method="POST" action="/agendamentos/<%= item.id %>/lembrete-enviado">
                  <button type="submit" class="btn btn-small">Marcar enviado</button>
                </form>
              <% } else { %>
                <form method="POST" action="/agendamentos/<%= item.id %>/lembrete-limpar" onsubmit="return confirm('Reabrir este lembrete como pendente?');">
                  <button type="submit" class="btn btn-outline btn-small">Reabrir</button>
                </form>
              <% } %>
              <a href="/agendamentos/<%= item.id %>/editar" class="btn btn-outline btn-small">Editar</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </section>
</main>
</body>
</html>
