<%- include('../partials/header', { title: 'Dentistas' }) %>
<%- include('../partials/sidebar', { currentPage: 'dentistas' }) %>
<main class="content">
  <%- include('../partials/topbar', { pageTitle: 'Dentistas', subtitle: 'Cadastre os dentistas uma única vez para usar o nome e o e-mail padronizados na agenda.' }) %>
  <div class="page-body">
    <div class="two-col">
      <div>
        <div class="card">
          <h3><%= editDentista ? 'Editar dentista' : 'Novo dentista' %></h3>
          <form method="POST" action="<%= editDentista ? '/dentistas/' + editDentista.id + '?_method=PUT' : '/dentistas' %>" class="form-grid">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="full">
              <label>Nome do dentista</label>
              <input type="text" name="nome" value="<%= editDentista?.nome||'' %>" required />
            </div>
            <div>
              <label>E-mail</label>
              <input type="email" name="email" value="<%= editDentista?.email||'' %>" />
            </div>
            <div>
              <label>Status</label>
              <select name="ativo">
                <option value="1" <%= !editDentista||Number(editDentista.ativo)===1?'selected':'' %>>Ativo</option>
                <option value="0" <%= editDentista&&Number(editDentista.ativo)===0?'selected':'' %>>Inativo</option>
              </select>
            </div>
            <div class="form-actions full">
              <button type="submit" class="btn"><%= editDentista ? 'Atualizar dentista' : 'Salvar dentista' %></button>
              <% if(editDentista){ %><a href="/dentistas" class="btn btn-outline">Limpar</a><% } else { %><button type="reset" class="btn btn-outline">Limpar</button><% } %>
            </div>
          </form>
        </div>
      </div>

      <div>
        <div class="card">
          <h3>Dentistas cadastrados</h3>
          <table>
            <thead>
              <tr><th>Nome</th><th>E-mail</th><th>Status</th><th>Ações</th></tr>
            </thead>
            <tbody>
              <% if(!dentistas.length){ %>
                <tr><td colspan="4" style="text-align:center;color:#9ca3af;padding:20px">Nenhum dentista cadastrado.</td></tr>
              <% } %>
              <% dentistas.forEach(function(d){ %>
                <tr>
                  <td><%= d.nome %></td>
                  <td><%= d.email||'-' %></td>
                  <td>
                    <span class="badge <%= Number(d.ativo)?'badge-green':'badge-gray' %>">
                      <%= Number(d.ativo)?'Ativo':'Inativo' %>
                    </span>
                  </td>
                  <td>
                    <div style="display:flex;gap:6px">
                      <a href="/dentistas/<%= d.id %>/editar" class="btn btn-outline btn-sm">Editar</a>
                      <form method="POST" action="/dentistas/<%= d.id %>?_method=PUT" style="display:inline">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                        <input type="hidden" name="ativo" value="<%= Number(d.ativo)?'0':'1' %>" />
                        <input type="hidden" name="nome" value="<%= d.nome %>" />
                        <input type="hidden" name="email" value="<%= d.email||'' %>" />
                        <button type="submit" class="btn btn-outline btn-sm"><%= Number(d.ativo)?'Desativar':'Ativar' %></button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</main>
</body>
</html>
