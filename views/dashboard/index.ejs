<%- include('../partials/header', { title: 'Dashboard' }) %>
<%- include('../partials/sidebar', { currentPage: 'dashboard' }) %>
<%
  var clinicaNome = String((user && user.clinica_nome) || 'sua clínica');

  function phoneToWa(raw) {
    var p = String(raw||'').replace(/\D/g,'');
    if(p.length===10||p.length===11) p='55'+p;
    return p.length>=12?p:'';
  }
  function waMsg(item) {
    return encodeURIComponent('Olá '+item.paciente_nome+', lembramos do seu agendamento em '+item.data_fmt+' às '+item.hora_inicio+'. Qualquer dúvida estamos à disposição. - '+clinicaNome);
  }
  var today = new Date().toISOString().slice(0,10);
%>
<main class="content">
  <%- include('../partials/topbar', { pageTitle: 'Dashboard', subtitle: 'Visão geral da semana e calendário visual' }) %>

  <div class="page-body">

    <% if (licenseInfo && licenseInfo.hasLicense) { %>
      <div class="license-banner <%= licenseInfo.isExpiringSoon ? 'warning' : 'ok' %>">
        <div>
          <strong>Licenca de uso:</strong>
          expira em <%= licenseInfo.expiresAtLabel %>
          <% if (typeof licenseInfo.daysRemaining === 'number') { %>
            (<%= licenseInfo.daysRemaining >= 0 ? licenseInfo.daysRemaining : 0 %> dias restantes)
          <% } %>
        </div>
        <% if (licenseInfo.isExpiringSoon) { %>
          <span class="license-banner-tag">Renove com o admin para evitar bloqueio</span>
        <% } %>
      </div>
    <% } %>

    <!-- TABS -->
    <div class="tabs">
      <% ['Resumo','Semanal','Mensal'].forEach(function(tab, i) {
        var key = ['dia','semana','mes'][i];
        var active = filters.selectedTab === key;
      %>
        <a href="/dashboard?data=<%= filters.selectedDate %>&aba=<%= key %><%= filters.dentistaId ? '&dentista_id='+filters.dentistaId : '' %>"
           class="tab-btn<%= active ? ' active' : '' %>"><%= tab %></a>
      <% }) %>
    </div>

    <!-- FILTER BAR -->
    <form method="GET" action="/dashboard" class="filter-bar">
      <input type="hidden" name="aba" value="<%= filters.selectedTab %>" />
      <div>
        <label>Semana base</label>
        <input type="date" name="data" value="<%= filters.selectedDate %>" />
      </div>
      <div>
        <label>Mês</label>
        <input type="month" name="mes" value="<%= filters.selectedDate.slice(0,7) %>" onchange="this.form.data.value=this.value+'-01';this.form.submit();" />
      </div>
      <div>
        <label>Dentista</label>
        <select name="dentista_id" onchange="this.form.submit()">
          <option value="">Todos os dentistas</option>
          <% dentistas.forEach(function(d){ %>
            <option value="<%= d.id %>" <%= filters.dentistaId==d.id?'selected':'' %>><%= d.nome %></option>
          <% }) %>
        </select>
      </div>
      <button type="submit" class="btn btn-sm">Atualizar</button>
    </form>

    <!-- KPI CARDS -->
    <div class="kpi-row">
      <div class="kpi-card">
        <span>Pacientes cadastrados</span>
        <strong><%= Number(stats.pacientes||0) %></strong>
      </div>
      <div class="kpi-card">
        <span>Agendamentos da semana</span>
        <strong><%= Number(stats.agendaSemana||0) %></strong>
      </div>
      <div class="kpi-card">
        <span>Atendidos</span>
        <strong><%= agendaDia.filter(function(a){return a.status==='concluido'||a.status==='atendido'}).length %></strong>
      </div>
      <% if (canViewFinancial) { %>
        <div class="kpi-card">
          <span>Receita lançada</span>
          <strong>R$ <%= Number(stats.receitaMes||0).toLocaleString('pt-BR',{minimumFractionDigits:2}) %></strong>
        </div>
      <% } else { %>
        <div class="kpi-card">
          <span>Agendamentos do mês</span>
          <strong><%= Number(stats.agendaMes||0) %></strong>
        </div>
      <% } %>
    </div>

    <!-- MAIN CONTENT: WEEK / MONTH / DAY + NEXT -->
    <div class="dashboard-row">

      <!-- LEFT: AGENDA -->
      <div>

        <% if (filters.selectedTab === 'semana') { %>
        <!-- WEEK VIEW -->
        <div class="card" style="padding:16px">
          <h3 style="margin-bottom:14px">Resumo da semana</h3>
          <div class="week-grid">
            <% agendaSemana.forEach(function(col) { %>
              <div class="week-col">
                <div class="week-col-header<%= col.iso===today?' today':'' %>">
                  <%= col.label %>
                </div>
                <div class="week-col-body">
                  <% if(!col.appointments.length) { %>
                    <p style="font-size:11px;color:#9ca3af;text-align:center;margin-top:8px">Sem agendamentos</p>
                  <% } %>
                  <% col.appointments.forEach(function(a) { %>
                    <div class="appt-card status-<%= a.status %>">
                      <span class="appt-time"><%= a.hora_inicio %> às <%= a.hora_fim %></span>
                      <span class="appt-dentist"> <%= a.dentista_nome %></span>
                      <span class="appt-patients"><%= a.paciente_nome %></span>
                      <% var wa=phoneToWa(a.telefone); if(wa){ %>
                        <a href="https://wa.me/<%= wa %>?text=<%= waMsg(a) %>" target="_blank" class="btn btn-whatsapp btn-sm" style="margin-top:4px">WhatsApp</a>
                      <% } %>
                    </div>
                  <% }) %>
                </div>
              </div>
            <% }) %>
          </div>
        </div>

        <% } else if (filters.selectedTab === 'mes') { %>
        <!-- MONTH VIEW -->
        <div class="card" style="padding:16px">
          <h3 style="margin-bottom:14px">Agenda do mês - <%= monthTitle %></h3>
          <div class="week-grid month-week-grid">
            <% monthCalendar.forEach(function(week){ %>
              <% week.forEach(function(cell){ %>
                <% if(!cell){ %>
                  <div class="week-col month-empty-col">
                    <div class="week-col-header">-</div>
                    <div class="week-col-body"></div>
                  </div>
                <% } else { %>
                  <div class="week-col month-day-col<%= cell.isSelected ? ' selected' : '' %>">
                    <div class="week-col-header<%= cell.isToday ? ' today' : '' %>">
                      <a href="/dashboard?data=<%= cell.iso %>&aba=dia<%= filters.dentistaId ? '&dentista_id='+filters.dentistaId : '' %>" class="month-day-link">
                        <%= new Date(cell.iso + 'T00:00:00').toLocaleDateString('pt-BR', { weekday: 'short', day: '2-digit', month: '2-digit' }) %>
                      </a>
                    </div>
                    <div class="week-col-body">
                      <% if(!cell.appointments.length) { %>
                        <p style="font-size:11px;color:#9ca3af;text-align:center;margin-top:8px">Sem agendamentos</p>
                      <% } %>
                      <% cell.appointments.forEach(function(a) { %>
                        <div class="appt-card status-<%= a.status %>">
                          <span class="appt-time"><%= a.hora_inicio %> às <%= a.hora_fim %></span>
                          <span class="appt-dentist"><%= a.dentista_nome %></span>
                          <span class="appt-patients"><%= a.paciente_nome %></span>
                          <% var wa=phoneToWa(a.telefone); if(wa){ %>
                            <a href="https://wa.me/<%= wa %>?text=<%= waMsg(a) %>" target="_blank" class="btn btn-whatsapp btn-sm" style="margin-top:4px">WhatsApp</a>
                          <% } %>
                        </div>
                      <% }) %>
                    </div>
                  </div>
                <% } %>
              <% }) %>
            <% }) %>
          </div>
        </div>

        <% } else { %>
        <!-- RESUMO/DIA VIEW (week grid = AgendaEA default) -->
        <div class="card" style="padding:16px">
          <h3 style="margin-bottom:14px">Resumo da semana</h3>
          <div class="week-grid">
            <% agendaSemana.forEach(function(col) { %>
              <div class="week-col">
                <div class="week-col-header<%= col.iso===today?' today':'' %>">
                  <%= col.label %>
                </div>
                <div class="week-col-body">
                  <% if(!col.appointments.length) { %>
                    <p style="font-size:11px;color:#9ca3af;text-align:center;margin-top:8px">Sem agendamentos</p>
                  <% } %>
                  <% col.appointments.forEach(function(a) { %>
                    <div class="appt-card status-<%= a.status %>">
                      <span class="appt-time"><%= a.hora_inicio %> às <%= a.hora_fim %></span>
                      <span class="appt-dentist"> <%= a.dentista_nome %></span>
                      <span class="appt-patients"><%= a.paciente_nome %></span>
                      <span class="appt-status"><%= a.status %></span>
                      <% var wa=phoneToWa(a.telefone); if(wa){ %>
                        <a href="https://wa.me/<%= wa %>?text=<%= waMsg(a) %>" target="_blank" class="btn btn-whatsapp btn-sm" style="margin-top:4px">WhatsApp</a>
                      <% } %>
                    </div>
                  <% }) %>
                </div>
              </div>
            <% }) %>
          </div>
        </div>

        <% if (canViewFinancial) { %>
          <!-- FINANCEIRO DO MES -->
          <div class="card">
            <h3>Financeiro do mês</h3>
            <div class="fin-grid">
              <div class="fin-card">
                <span>Recebido no mês</span>
                <strong>R$ <%= Number(stats.receitaMes||0).toLocaleString('pt-BR',{minimumFractionDigits:2}) %></strong>
              </div>
              <div class="fin-card">
                <span>Recibos emitidos</span>
                <strong><%= ultimosRecibos.length %></strong>
              </div>
              <div class="fin-card">
                <span>Ticket médio</span>
                <strong>R$ <%= ultimosRecibos.length ? (Number(stats.receitaMes||0)/ultimosRecibos.length).toLocaleString('pt-BR',{minimumFractionDigits:2}) : '0,00' %></strong>
              </div>
              <div class="fin-card">
                <span>Estimado em agenda</span>
                <strong>R$ <%= Number(agendaDia.reduce(function(s,a){return s+Number(a.valor_estimado||0)},0)).toLocaleString('pt-BR',{minimumFractionDigits:2}) %></strong>
              </div>
            </div>
            <p style="font-size:12px;color:#6b7280;margin-top:8px">
              Período analisado: 01/<%= filters.selectedDate.slice(5,7) %>/<%= filters.selectedDate.slice(0,4) %> até
              <% var d=new Date(filters.selectedDate.slice(0,4),filters.selectedDate.slice(5,7),0); %>
              <%= d.getDate() %>/<%= filters.selectedDate.slice(5,7) %>/<%= filters.selectedDate.slice(0,4) %>.
            </p>
          </div>
        <% } %>
        <% } %>

      </div>

      <!-- RIGHT: PRÓXIMOS ATENDIMENTOS + ANIVERSARIANTES -->
      <div>
        <div class="card">
          <h3>Próximos atendimentos</h3>
          <div class="proximos-panel">
            <% var proximos = agendaDia.slice(0,8); %>
            <% if(!proximos.length){ %>
              <div class="empty-state"><p>Sem agendamentos para hoje</p></div>
            <% } %>
            <% proximos.forEach(function(a) { %>
              <div class="proximo-card status-<%= a.status %>">
                <div class="proximo-name"><%= a.paciente_nome %></div>
                <div class="proximo-info"><%= a.data_fmt %>  <%= a.hora_inicio %> às <%= a.hora_fim %>  <%= a.dentista_nome %></div>
                <div class="proximo-actions">
                  <form method="POST" action="/dashboard/agendamentos/<%= a.id %>/status" style="display:inline">
                    <select name="status" class="status-select" onchange="this.form.submit()">
                      <% ['agendado','confirmado','concluido','cancelado','falta'].forEach(function(st){ %>
                        <option value="<%= st %>" <%= a.status===st?'selected':'' %>><%= st.charAt(0).toUpperCase()+st.slice(1) %></option>
                      <% }) %>
                    </select>
                    <input type="hidden" name="_redirect" value="<%= '/dashboard?data='+filters.selectedDate+'&aba=dia' %>" />
                  </form>
                  <% var wa=phoneToWa(a.telefone); if(wa){ %>
                    <a href="https://wa.me/<%= wa %>?text=<%= waMsg(a) %>" target="_blank" class="btn btn-whatsapp btn-sm">WhatsApp</a>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="card">
          <h3>Aniversariantes do mês</h3>
          <% if(!aniversariantes.length){ %>
            <div class="empty-state"><p>Nenhum aniversariante</p></div>
          <% } %>
          <ul class="birthday-list">
            <% aniversariantes.forEach(function(p){ %>
              <li>
                <span><%= p.nome %></span>
                <span class="birthday-date"><%= p.data_nasc_fmt %></span>
              </li>
            <% }) %>
          </ul>
        </div>
      </div>

    </div><!-- end dashboard-row -->

  </div><!-- end page-body -->
</main>
</body>
</html>
