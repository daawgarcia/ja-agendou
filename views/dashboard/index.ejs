<%- include('../partials/header', { title: 'Dashboard' }) %>
<%- include('../partials/sidebar') %>
<%
  function phoneToWhatsapp(rawPhone) {
    var phone = String(rawPhone || '').replace(/\D/g, '');
    if (phone.length === 10 || phone.length === 11) {
      phone = '55' + phone;
    }
    return phone.length >= 12 ? phone : '';
  }

  function buildDashboardQuery(dateValue, tabValue) {
    var query = '?data=' + encodeURIComponent(dateValue || filters.selectedDate);
    query += '&aba=' + encodeURIComponent(tabValue || filters.selectedTab || 'dia');
    if (filters.dentistaId) query += '&dentista_id=' + encodeURIComponent(filters.dentistaId);
    if (filters.status) query += '&status=' + encodeURIComponent(filters.status);
    return query;
  }

  function whatsappMessage(item) {
    return encodeURIComponent('Olá ' + item.paciente_nome + ', lembrando do seu agendamento em ' + item.data_fmt + ' às ' + item.hora_inicio + '. Qualquer dúvida, estamos à disposição. - Já Agendou');
  }
%>
<main class="content dashboard-page">
  <%- include('../partials/topbar', { pageTitle: 'Dashboard', subtitle: 'Agenda operacional no estilo do Já Agendou.' }) %>

  <section class="cards cards-5 dashboard-cards">
    <div class="card stat-card accent-blue">
      <span>Pacientes</span>
      <h2><%= Number(stats.pacientes || 0) %></h2>
      <small>base total da clínica</small>
    </div>
    <div class="card stat-card accent-cyan">
      <span>Agenda do dia</span>
      <h2><%= Number(stats.agendaDia || 0) %></h2>
      <small><%= filters.selectedDate %></small>
    </div>
    <div class="card stat-card success-card">
      <span>Confirmados no dia</span>
      <h2><%= Number(stats.confirmadosDia || 0) %></h2>
      <small>prontos para atendimento</small>
    </div>
    <div class="card stat-card accent-slate">
      <span>Agenda da semana</span>
      <h2><%= Number(stats.agendaSemana || 0) %></h2>
      <small><%= weekRangeLabel %></small>
    </div>
    <div class="card stat-card accent-gold">
      <span>Receita do mês</span>
      <h2>R$ <%= Number(stats.receitaMes || 0).toFixed(2) %></h2>
      <small><%= monthTitle.charAt(0).toUpperCase() + monthTitle.slice(1) %></small>
    </div>
  </section>

  <section class="dashboard-top-grid">
    <article class="card dashboard-filter-card">
      <div class="section-header compact-header">
        <div>
          <h3>Filtro operacional</h3>
          <p>Escolha a data-base e refine a agenda.</p>
        </div>
      </div>
      <form method="GET" action="/dashboard" class="grid-form grid-4" id="dashboardFilterForm">
        <input type="hidden" name="aba" id="abaInput" value="<%= filters.selectedTab %>" />
        <div>
          <label>Data-base</label>
          <input type="date" name="data" value="<%= filters.selectedDate %>" />
        </div>
        <div>
          <label>Dentista</label>
          <select name="dentista_id">
            <option value="">Todos</option>
            <% dentistas.forEach(function(dentista) { %>
              <option value="<%= dentista.id %>" <%= String(filters.dentistaId || '') === String(dentista.id) ? 'selected' : '' %>><%= dentista.nome %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label>Status</label>
          <select name="status">
            <option value="">Todos</option>
            <% ['agendado', 'confirmado', 'concluido', 'cancelado'].forEach(function(status) { %>
              <option value="<%= status %>" <%= filters.status === status ? 'selected' : '' %>><%= status %></option>
            <% }) %>
          </select>
        </div>
        <div class="filter-actions">
          <button type="submit" class="btn">Atualizar agenda</button>
          <a href="/dashboard" class="btn btn-outline">Limpar</a>
        </div>
      </form>
    </article>

    <article class="card quick-actions-card">
      <div class="section-header compact-header">
        <div>
          <h3>Ações rápidas</h3>
          <p>Atalhos para o fluxo de recepção.</p>
        </div>
      </div>
      <div class="quick-actions-grid">
        <a href="/agendamentos" class="quick-link quick-link-primary">Abrir agenda completa</a>
        <a href="/pacientes" class="quick-link">Cadastrar ou localizar paciente</a>
        <a href="/recibos" class="quick-link">Lançar recibos</a>
        <% if (user && (user.perfil === 'super_admin' || user.perfil === 'admin')) { %>
          <a href="/relatorios" class="quick-link">Ver relatórios</a>
        <% } %>
      </div>
    </article>
  </section>

  <section class="card agenda-card-v2">
    <div class="section-header agenda-header-v2">
      <div>
        <h3>Agenda assistida</h3>
        <p>Visualização diária, semanal e mensal com ações rápidas.</p>
      </div>
      <div class="tab-group">
        <button type="button" class="tab-btn <%= filters.selectedTab === 'dia' ? 'active' : '' %>" data-tab="dia">Dia</button>
        <button type="button" class="tab-btn <%= filters.selectedTab === 'semana' ? 'active' : '' %>" data-tab="semana">Semana</button>
        <button type="button" class="tab-btn <%= filters.selectedTab === 'mes' ? 'active' : '' %>" data-tab="mes">Mês</button>
      </div>
    </div>

    <div class="status-strip">
      <span class="status-pill status-pill-agendado">Agendados: <strong><%= Number(statusResumo.agendado || 0) %></strong></span>
      <span class="status-pill status-pill-confirmado">Confirmados: <strong><%= Number(statusResumo.confirmado || 0) %></strong></span>
      <span class="status-pill status-pill-concluido">Concluídos: <strong><%= Number(statusResumo.concluido || 0) %></strong></span>
      <span class="status-pill status-pill-cancelado">Cancelados: <strong><%= Number(statusResumo.cancelado || 0) %></strong></span>
    </div>

    <div id="tab-dia" class="tab-panel <%= filters.selectedTab === 'dia' ? 'active' : '' %>">
      <% if (!agendaDia.length) { %>
        <p class="empty-msg">Nenhum agendamento para a data selecionada.</p>
      <% } else { %>
        <div class="agenda-list-v2">
          <% agendaDia.forEach(function(item) { %>
            <% var whatsappPhone = phoneToWhatsapp(item.telefone); %>
            <article class="agenda-card-item status-<%= item.status %>">
              <div class="agenda-time-block">
                <strong><%= item.hora_inicio %></strong>
                <span>até <%= item.hora_fim %></span>
              </div>
              <div class="agenda-main-block">
                <div class="agenda-main-row">
                  <h4><%= item.paciente_nome %></h4>
                  <span class="badge badge-<%= item.status %>"><%= item.status %></span>
                </div>
                <div class="agenda-meta-row">
                  <span><strong>Serviço:</strong> <%= item.servico_nome %></span>
                  <span><strong>Dentista:</strong> <%= item.dentista_nome %></span>
                  <span><strong>Valor:</strong> R$ <%= Number(item.valor_estimado || 0).toFixed(2) %></span>
                </div>
                <% if (item.observacoes) { %>
                  <p class="agenda-observacao"><%= item.observacoes %></p>
                <% } %>
              </div>
              <div class="agenda-side-actions">
                <div class="agenda-link-actions">
                  <% if (whatsappPhone) { %>
                    <a href="https://wa.me/<%= whatsappPhone %>?text=<%= whatsappMessage(item) %>" target="_blank" rel="noopener" class="btn btn-whatsapp btn-small">WhatsApp</a>
                  <% } %>
                  <a href="/agendamentos/<%= item.id %>/editar" class="btn btn-outline btn-small">Editar</a>
                </div>
                <div class="agenda-status-actions">
                  <% if (item.status === 'agendado') { %>
                    <form method="POST" action="/dashboard/agendamentos/<%= item.id %>/status">
                      <input type="hidden" name="status" value="confirmado" />
                      <button type="submit" class="btn btn-small">Confirmar</button>
                    </form>
                  <% } %>
                  <% if (item.status !== 'concluido' && item.status !== 'cancelado') { %>
                    <form method="POST" action="/dashboard/agendamentos/<%= item.id %>/status">
                      <input type="hidden" name="status" value="concluido" />
                      <button type="submit" class="btn btn-outline btn-small">Concluir</button>
                    </form>
                  <% } %>
                  <% if (item.status !== 'cancelado') { %>
                    <form method="POST" action="/dashboard/agendamentos/<%= item.id %>/status" onsubmit="return confirm('Cancelar este agendamento?');">
                      <input type="hidden" name="status" value="cancelado" />
                      <button type="submit" class="btn btn-danger btn-small">Cancelar</button>
                    </form>
                  <% } %>
                </div>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div id="tab-semana" class="tab-panel <%= filters.selectedTab === 'semana' ? 'active' : '' %>">
      <div class="week-label">Semana: <%= weekRangeLabel %></div>
      <div class="semana-grid-v2">
        <% agendaSemana.forEach(function(day) { %>
          <div class="semana-col-v2 <%= day.isToday ? 'semana-hoje' : '' %> <%= day.isSelected ? 'semana-selected' : '' %>">
            <a class="semana-heading-link" href="/dashboard<%= buildDashboardQuery(day.iso, 'dia') %>">
              <div class="semana-header-v2"><%= day.label %></div>
            </a>
            <% if (!day.appointments.length) { %>
              <div class="semana-vazio">Livre</div>
            <% } else { %>
              <% day.appointments.forEach(function(item) { %>
                <% var weekPhone = phoneToWhatsapp(item.telefone); %>
                <div class="semana-item-v2 status-<%= item.status %>">
                  <strong><%= item.hora_inicio %></strong>
                  <span><%= item.paciente_nome %></span>
                  <small><%= item.servico_nome %></small>
                  <div class="semana-actions-inline">
                    <% if (weekPhone) { %>
                      <a href="https://wa.me/<%= weekPhone %>?text=<%= whatsappMessage(item) %>" target="_blank" rel="noopener" class="mini-link">WhatsApp</a>
                    <% } %>
                    <a href="/agendamentos/<%= item.id %>/editar" class="mini-link">Editar</a>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>
        <% }) %>
      </div>
    </div>

    <div id="tab-mes" class="tab-panel <%= filters.selectedTab === 'mes' ? 'active' : '' %>">
      <div class="mes-title-v2"><%= monthTitle.charAt(0).toUpperCase() + monthTitle.slice(1) %></div>
      <table class="mes-grid-v2">
        <thead>
          <tr>
            <% ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sab'].forEach(function(label) { %>
              <th><%= label %></th>
            <% }) %>
          </tr>
        </thead>
        <tbody>
          <% monthCalendar.forEach(function(week) { %>
            <tr>
              <% week.forEach(function(day) { %>
                <% if (!day) { %>
                  <td class="mes-vazio"></td>
                <% } else { %>
                  <td class="mes-dia-v2 <%= day.isToday ? 'mes-dia-hoje' : '' %> <%= day.isSelected ? 'mes-dia-selected' : '' %>">
                    <a class="mes-day-link" href="/dashboard<%= buildDashboardQuery(day.iso, 'dia') %>">
                      <span class="mes-num"><%= day.day %></span>
                    </a>
                    <% day.appointments.slice(0, 4).forEach(function(item) { %>
                      <div class="mes-evento-v2 status-<%= item.status %>"><%= item.hora_inicio %> <%= item.paciente_nome.split(' ')[0] %></div>
                    <% }) %>
                    <% if (day.appointments.length > 4) { %>
                      <div class="mes-mais">+<%= day.appointments.length - 4 %> agendamentos</div>
                    <% } %>
                  </td>
                <% } %>
              <% }) %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="dashboard-bottom-grid">
    <article class="card bottom-card">
      <div class="section-header compact-header">
        <div>
          <h3>Produção por dentista</h3>
          <p>Resumo do mês selecionado.</p>
        </div>
      </div>
      <table>
        <thead>
          <tr>
            <th>Dentista</th>
            <th>Atendimentos</th>
            <th>Valor estimado</th>
          </tr>
        </thead>
        <tbody>
          <% if (!producaoDentistas.length) { %>
            <tr><td colspan="3">Nenhum dado para o período.</td></tr>
          <% } %>
          <% producaoDentistas.forEach(function(item) { %>
            <tr>
              <td><%= item.dentista_nome %></td>
              <td><%= Number(item.total || 0) %></td>
              <td>R$ <%= Number(item.valor_total || 0).toFixed(2) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </article>

    <article class="card bottom-card">
      <div class="section-header compact-header">
        <div>
          <h3>Últimos recibos</h3>
          <p>Movimentação financeira recente.</p>
        </div>
      </div>
      <div class="stack-list">
        <% if (!ultimosRecibos.length) { %>
          <p class="empty-msg compact-empty">Nenhum recibo cadastrado.</p>
        <% } %>
        <% ultimosRecibos.forEach(function(item) { %>
          <div class="stack-item">
            <div>
              <strong><%= item.paciente_nome || 'Sem paciente' %></strong>
              <span><%= item.descricao %> - <%= item.data_fmt %></span>
            </div>
            <strong>R$ <%= Number(item.valor || 0).toFixed(2) %></strong>
          </div>
        <% }) %>
      </div>
    </article>

    <article class="card bottom-card">
      <div class="section-header compact-header">
        <div>
          <h3>Aniversariantes</h3>
          <p>Pacientes do mês com acesso rápido ao WhatsApp.</p>
        </div>
      </div>
      <div class="stack-list">
        <% if (!aniversariantes.length) { %>
          <p class="empty-msg compact-empty">Nenhum aniversariante neste mês.</p>
        <% } %>
        <% aniversariantes.forEach(function(item) { %>
          <% var birthdayPhone = phoneToWhatsapp(item.telefone); %>
          <div class="stack-item">
            <div>
              <strong><%= item.nome %></strong>
              <span>Faz aniversário em <%= item.data_nasc_fmt %></span>
            </div>
            <% if (birthdayPhone) { %>
              <a href="https://wa.me/<%= birthdayPhone %>?text=<%= encodeURIComponent('Olá ' + item.nome + ', toda a equipe da Já Agendou deseja um feliz aniversário!') %>" target="_blank" rel="noopener" class="btn btn-whatsapp btn-small">Parabenizar</a>
            <% } else { %>
              <span class="muted-inline">Sem telefone</span>
            <% } %>
          </div>
        <% }) %>
      </div>
    </article>
  </section>
</main>

<script>
  document.querySelectorAll('.tab-btn').forEach(function (button) {
    button.addEventListener('click', function () {
      var nextTab = button.dataset.tab;
      document.getElementById('abaInput').value = nextTab;
      document.querySelectorAll('.tab-btn').forEach(function (item) {
        item.classList.toggle('active', item === button);
      });
      document.querySelectorAll('.tab-panel').forEach(function (panel) {
        panel.classList.toggle('active', panel.id === 'tab-' + nextTab);
      });
    });
  });
</script>
</body>
</html>
