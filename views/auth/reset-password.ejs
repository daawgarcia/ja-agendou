<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nova senha - Já Agendou!</title>
  <link rel="stylesheet" href="/css/styles.css?v=<%= Date.now() %>" />
</head>
<body class="auth-body">

<div class="auth-box">
  <img src="/images/logo-ja-agendou.png" alt="Já Agendou!" class="auth-logo" />

  <h1>Criar nova senha</h1>
  <p>Defina sua nova senha para voltar a acessar o sistema.</p>

  <% if (error) { %>
    <div class="alert alert-error" style="text-align:left"><%= error %></div>
  <% } %>

  <% if (info) { %>
    <div class="alert alert-info" style="text-align:left"><%= info %></div>
  <% } %>

  <% if (token) { %>
    <form method="POST" action="/reset-password">
      <input type="hidden" name="token" value="<%= token %>" />
      <label>Nova senha</label>
      <input type="password" name="senha" placeholder="Mínimo de 6 caracteres" required minlength="6" />
      <label>Confirmar senha</label>
      <input type="password" name="confirmar_senha" placeholder="Digite novamente a nova senha" required minlength="6" />
      <button type="submit" class="btn">Salvar nova senha</button>
    </form>
  <% } %>

  <div class="auth-alt-link">
    <a href="/login">Voltar ao login</a>
  </div>
</div>

</body>
</html>