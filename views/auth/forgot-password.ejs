<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Recuperar senha - Já Agendou!</title>
  <link rel="stylesheet" href="/css/styles.css?v=<%= Date.now() %>" />
  <% if (ga4MeasurementId) { %>
    <script async src="https://www.googletagmanager.com/gtag/js?id=<%= ga4MeasurementId %>"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '<%= ga4MeasurementId %>');
    </script>
  <% } %>
</head>
<body class="auth-body">

<div class="auth-box">
  <img src="/images/logo-ja-agendou.png" alt="Já Agendou!" class="auth-logo" />

  <h1>Recuperar senha</h1>
  <p>Informe seu e-mail de acesso para receber um link de redefinição.</p>

  <% if (error) { %>
    <div class="alert alert-error" style="text-align:left"><%= error %></div>
  <% } %>

  <% if (info) { %>
    <div class="alert alert-info" style="text-align:left"><%= info %></div>
  <% } %>

  <form method="POST" action="/forgot-password">
    <label>E-mail</label>
    <input type="email" name="email" placeholder="admin@clinica.com" required />
    <button type="submit" class="btn">Enviar link de redefinição</button>
  </form>

  <div class="auth-alt-link">
    <a href="/login">Voltar ao login</a>
  </div>
</div>

</body>
</html>