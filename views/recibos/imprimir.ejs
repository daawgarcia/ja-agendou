<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <title>Recibo #<%= recibo.id %></title>
  <style>
    body { font-family: Arial, sans-serif; margin: 30px; color: #222; }
    .box { border: 1px solid #bbb; padding: 20px; }
    .row { margin-bottom: 10px; }
    h1 { margin-top: 0; }
    .assinatura { margin-top: 40px; border-top: 1px solid #555; width: 260px; padding-top: 6px; }
    @media print { .no-print { display: none; } }
  </style>
</head>
<body>
  <button class="no-print" onclick="window.print()">Imprimir</button>
  <div class="box">
    <h1>Recibo</h1>
    <div class="row"><strong>Numero:</strong> #<%= recibo.id %></div>
    <div class="row"><strong>Data:</strong> <%= recibo.data_recibo %></div>
    <div class="row"><strong>Paciente:</strong> <%= recibo.paciente_nome %></div>
    <div class="row"><strong>Valor:</strong> R$ <%= Number(recibo.valor || 0).toFixed(2) %></div>
    <div class="row"><strong>Descricao:</strong> <%= recibo.descricao %></div>
    <div class="row"><strong>Documento do pagador:</strong> <%= recibo.documento_pagador || '-' %></div>
    <div class="row"><strong>Observacoes:</strong> <%= recibo.observacoes || '-' %></div>
    <div class="assinatura">Assinatura</div>
  </div>
</body>
</html>
