<%- include('../partials/header', { title: 'Pacientes' }) %>
<%- include('../partials/sidebar', { currentPage: 'pacientes' }) %>
<main class="content">
  <%- include('../partials/topbar', { pageTitle: 'Pacientes', subtitle: 'Cadastre e gerencie pacientes. Importação via Excel/CSV disponível.' }) %>
  <div class="page-body">
    <div class="two-col">
      <!-- FORM -->
      <div>
        <div class="card">
          <h3><%= editPaciente ? 'Editar paciente' : 'Novo paciente' %></h3>
          <form method="POST" action="<%= editPaciente ? '/pacientes/' + editPaciente.id + '?_method=PUT' : '/pacientes' %>" class="form-grid">
            <div class="full">
              <label>Nome completo</label>
              <input type="text" name="nome" value="<%= editPaciente?.nome||'' %>" required />
            </div>
            <div>
              <label>Telefone</label>
              <input type="text" name="telefone" value="<%= editPaciente?.telefone||'' %>" />
            </div>
            <div>
              <label>E-mail</label>
              <input type="email" name="email" value="<%= editPaciente?.email||'' %>" />
            </div>
            <div>
              <label>Data de nascimento</label>
              <input type="date" name="data_nascimento" value="<%= editPaciente?.data_nascimento||'' %>" />
            </div>
            <div>
              <label>Convênio</label>
              <input type="text" name="convenio" value="<%= editPaciente?.convenio||'' %>" />
            </div>
            <div class="full">
              <label>Endereço</label>
              <input type="text" name="endereco" value="<%= editPaciente?.endereco||'' %>" />
            </div>
            <div>
              <label>Sexo</label>
              <select name="sexo">
                <option value="">Selecione</option>
                <option value="F" <%= editPaciente?.sexo==='F'?'selected':'' %>>Feminino</option>
                <option value="M" <%= editPaciente?.sexo==='M'?'selected':'' %>>Masculino</option>
                <option value="O" <%= editPaciente?.sexo==='O'?'selected':'' %>>Outro</option>
              </select>
            </div>
            <div>
              <label>CPF</label>
              <input type="text" name="cpf" value="<%= editPaciente?.cpf||'' %>" />
            </div>
            <div>
              <label>RG</label>
              <input type="text" name="rg" value="<%= editPaciente?.rg||'' %>" />
            </div>
            <div>
              <label>Responsável</label>
              <input type="text" name="responsavel" value="<%= editPaciente?.responsavel||'' %>" />
            </div>
            <div class="full">
              <label>Observações</label>
              <textarea name="observacoes" rows="3"><%= editPaciente?.observacoes||'' %></textarea>
            </div>
            <div class="form-actions full">
              <button type="submit" class="btn"><%= editPaciente ? 'Atualizar paciente' : 'Salvar paciente' %></button>
              <% if(editPaciente){ %><a href="/pacientes" class="btn btn-outline">Limpar</a><% } else { %>
              <button type="reset" class="btn btn-outline">Limpar</button><% } %>
            </div>
          </form>
        </div>

        <div class="card">
          <h3>Importar Excel / CSV</h3>

          <% if (typeof importError !== 'undefined' && importError) { %>
            <div class="alert alert-error" style="margin-bottom:12px"><%= importError %></div>
          <% } %>
          <% if (typeof importSuccess !== 'undefined' && importSuccess) { %>
            <div class="alert alert-success" style="margin-bottom:12px"><%= importSuccess %></div>
          <% } %>

          <p style="font-size:12px;color:#6b7280;line-height:1.6;margin-bottom:12px">
            Baixe o template, preencha os dados dos pacientes e envie o arquivo para importar em lote.
            A coluna <strong>Nome</strong> é obrigatória.
          </p>

          <a href="/templates/template-pacientes.xlsx" class="btn btn-outline btn-sm" style="margin-bottom:14px" download>
            ⬇ Baixar template Excel
          </a>

          <form method="POST" action="/pacientes/import" enctype="multipart/form-data" style="display:flex;gap:8px;align-items:end">
            <div style="flex:1">
              <label style="font-size:12px">Arquivo (.xlsx ou .csv)</label>
              <input type="file" name="arquivo" accept=".xlsx,.xls,.csv" required style="font-size:13px" />
            </div>
            <button type="submit" class="btn btn-sm">Importar</button>
          </form>
        </div>
      </div>

      <!-- LIST -->
      <div>
        <div class="card">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">
            <h3 style="margin-bottom:0;border-bottom:none;padding-bottom:0">Pacientes cadastrados</h3>
          </div>
          <form method="GET" action="/pacientes" style="margin-bottom:12px;display:flex;gap:8px">
            <input type="text" name="busca" value="<%= busca||'' %>" placeholder="Buscar por nome..." style="flex:1" />
            <button type="submit" class="btn btn-sm">Buscar</button>
          </form>
          <table>
            <thead>
              <tr>
                <th>Nome</th>
                <th>CPF</th>
                <th>Telefone</th>
                <th>Responsável</th>
                <th>Ações</th>
              </tr>
            </thead>
            <tbody>
              <% if(!pacientes.length){ %>
                <tr><td colspan="5" style="text-align:center;color:#9ca3af;padding:20px">Nenhum paciente encontrado.</td></tr>
              <% } %>
              <% pacientes.forEach(function(p){ %>
                <tr>
                  <td><%= p.nome %></td>
                  <td><%= p.cpf||'-' %></td>
                  <td><%= p.telefone||'-' %></td>
                  <td><%= p.responsavel||'-' %></td>
                  <td>
                    <a href="/pacientes/<%= p.id %>/editar" class="btn btn-outline btn-sm">Editar</a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</main>
</body>
</html>
