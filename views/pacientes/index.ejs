<%- include('../partials/header', { title: 'Pacientes' }) %>
<%- include('../partials/sidebar', { currentPage: 'pacientes' }) %>
<main class="content">
  <%- include('../partials/topbar', { pageTitle: 'Pacientes', subtitle: 'Cadastre e gerencie pacientes. Importação via Excel/CSV disponível.' }) %>
  <div class="page-body">

    <!-- TOOLBAR -->
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:10px">
      <div style="display:flex;gap:8px;align-items:center;flex:1;min-width:220px">
        <input id="buscaLive" type="text" placeholder="Buscar por nome, telefone ou CPF..." style="flex:1;max-width:420px" />
        <span id="totalCount" style="font-size:12px;color:#6b7280;white-space:nowrap"></span>
      </div>
      <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
        <button class="btn btn-sm btn-outline" onclick="abrirImport()">⬆ Importar</button>
        <button class="btn btn-sm" onclick="abrirModal()">+ Novo paciente</button>
      </div>
    </div>

    <!-- NOTIFICAÇÕES -->
    <% if (importError) { %>
      <div class="alert alert-error" style="margin-bottom:12px"><%= importError %></div>
    <% } %>
    <% if (importSuccess) { %>
      <div class="alert alert-success" style="margin-bottom:12px"><%= importSuccess %></div>
    <% } %>

    <!-- TABELA -->
    <div class="card" style="padding:0;overflow:hidden">
      <table id="tabelaPacientes">
        <thead>
          <tr>
            <th>Nome</th>
            <th>CPF</th>
            <th>Telefone</th>
            <th>CEP</th>
            <th>Responsável</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody id="corpoTabela">
          <% if(!pacientes.length){ %>
            <tr><td colspan="6" style="text-align:center;color:#9ca3af;padding:24px">Nenhum paciente cadastrado.</td></tr>
          <% } %>
          <% pacientes.forEach(function(p){ %>
            <tr data-nome="<%= (p.nome||'').toLowerCase() %>" data-tel="<%= (p.telefone||'').toLowerCase() %>" data-cpf="<%= (p.cpf||'').toLowerCase() %>">
              <td><%= p.nome %></td>
              <td><%= p.cpf||'-' %></td>
              <td><%= p.telefone||'-' %></td>
              <td><%= p.cep||'-' %></td>
              <td><%= p.responsavel||'-' %></td>
              <td>
                <button class="btn btn-outline btn-sm" onclick="editarPaciente(<%= p.id %>)">Editar</button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  </div>
</main>

<!-- MODAL PACIENTE -->
<div id="modalPaciente" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;overflow-y:auto;padding:24px 0">
  <div style="background:#fff;border-radius:12px;max-width:700px;width:94%;margin:0 auto;padding:28px 28px 20px;position:relative">
    <button onclick="fecharModal()" style="position:absolute;top:14px;right:16px;background:none;border:none;font-size:22px;cursor:pointer;color:#6b7280" title="Fechar">&times;</button>
    <h3 id="modalTitulo" style="margin:0 0 20px">Novo paciente</h3>
    <form id="formPaciente" method="POST" action="/pacientes" class="form-grid">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="_method" id="formMethod" value="">
      <div class="full">
        <label>Nome completo *</label>
        <input type="text" name="nome" id="fNome" required />
      </div>
      <div>
        <label>Telefone</label>
        <input type="text" name="telefone" id="fTelefone" />
      </div>
      <div>
        <label>E-mail</label>
        <input type="email" name="email" id="fEmail" />
      </div>
      <div>
        <label>Data de nascimento</label>
        <input type="date" name="data_nascimento" id="fDataNasc" />
      </div>
      <div>
        <label>CPF</label>
        <input type="text" name="cpf" id="fCpf" maxlength="14" placeholder="000.000.000-00" autocomplete="off" />
        <small id="cpfErro" style="color:#dc3545;font-size:11px;display:none">CPF inválido</small>
      </div>
      <div>
        <label>RG</label>
        <input type="text" name="rg" id="fRg" />
      </div>
      <div>
        <label>Sexo</label>
        <select name="sexo" id="fSexo">
          <option value="">Selecione</option>
          <option value="F">Feminino</option>
          <option value="M">Masculino</option>
          <option value="O">Outro</option>
        </select>
      </div>
      <div>
        <label>Convênio</label>
        <input type="text" name="convenio" id="fConvenio" />
      </div>
      <div>
        <label>CEP</label>
        <div style="display:flex;gap:6px;align-items:center">
          <input type="text" name="cep" id="fCep" maxlength="9" placeholder="00000-000" style="flex:1" />
          <span id="cepSpinner" style="display:none;font-size:12px;color:#6b7280">buscando...</span>
        </div>
        <small id="cepErro" style="color:#dc3545;font-size:11px;display:none">CEP não encontrado</small>
      </div>
      <div class="full">
        <label>Endereço</label>
        <input type="text" name="endereco" id="fEndereco" />
      </div>
      <div class="full">
        <label>Responsável</label>
        <input type="text" name="responsavel" id="fResponsavel" />
      </div>
      <div class="full">
        <label>Observações</label>
        <textarea name="observacoes" id="fObservacoes" rows="3"></textarea>
      </div>
      <div class="form-actions full" style="margin-top:8px">
        <button type="submit" class="btn" id="btnSalvar">Salvar paciente</button>
        <button type="button" class="btn btn-outline" onclick="fecharModal()">Cancelar</button>
      </div>
    </form>
  </div>
</div>

<!-- MODAL IMPORTAR -->
<div id="modalImport" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;padding:24px 0">
  <div style="background:#fff;border-radius:12px;max-width:500px;width:94%;margin:0 auto;padding:28px;position:relative">
    <button onclick="fecharImport()" style="position:absolute;top:14px;right:16px;background:none;border:none;font-size:22px;cursor:pointer;color:#6b7280">&times;</button>
    <h3 style="margin:0 0 16px">Importar pacientes</h3>
    <p style="font-size:13px;color:#6b7280;margin-bottom:14px">
      Baixe o template, preencha os dados e envie. A coluna <strong>Nome</strong> é obrigatória.
    </p>
    <a href="/templates/template-pacientes.xlsx" class="btn btn-outline btn-sm" style="margin-bottom:16px;display:inline-block" download>⬇ Baixar template Excel</a>
    <form method="POST" action="/pacientes/import" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div style="margin-bottom:12px">
        <label style="font-size:13px">Arquivo (.xlsx ou .csv)</label>
        <input type="file" name="arquivo" accept=".xlsx,.xls,.csv" required style="font-size:13px;margin-top:4px" />
      </div>
      <button type="submit" class="btn">Importar</button>
    </form>
  </div>
</div>

<script>
(function () {
  const rows = Array.from(document.querySelectorAll('#corpoTabela tr[data-nome]'));
  const totalCount = document.getElementById('totalCount');

  function updateCount(n) {
    totalCount.textContent = n + ' paciente' + (n !== 1 ? 's' : '');
  }
  updateCount(rows.length);

  document.getElementById('buscaLive').addEventListener('input', function () {
    const q = this.value.toLowerCase().trim();
    let visible = 0;
    rows.forEach(function (row) {
      const match = !q
        || row.dataset.nome.includes(q)
        || row.dataset.tel.includes(q)
        || row.dataset.cpf.includes(q);
      row.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    updateCount(visible);
  });

  // Modal paciente
  window.abrirModal = function () {
    document.getElementById('modalTitulo').textContent = 'Novo paciente';
    document.getElementById('formPaciente').action = '/pacientes';
    document.getElementById('formMethod').value = '';
    document.getElementById('btnSalvar').textContent = 'Salvar paciente';
    document.getElementById('formPaciente').reset();
    document.getElementById('modalPaciente').style.display = 'block';
    document.body.style.overflow = 'hidden';
    document.getElementById('fNome').focus();
  };

  window.fecharModal = function () {
    document.getElementById('modalPaciente').style.display = 'none';
    document.body.style.overflow = '';
  };

  window.editarPaciente = function (id) {
    fetch('/pacientes/' + id + '/json')
      .then(function (r) { return r.json(); })
      .then(function (p) {
        document.getElementById('modalTitulo').textContent = 'Editar paciente';
        document.getElementById('formPaciente').action = '/pacientes/' + id + '?_method=PUT';
        document.getElementById('formMethod').value = 'PUT';
        document.getElementById('btnSalvar').textContent = 'Atualizar paciente';
        document.getElementById('fNome').value        = p.nome || '';
        document.getElementById('fTelefone').value    = p.telefone || '';
        document.getElementById('fEmail').value       = p.email || '';
        document.getElementById('fDataNasc').value    = p.data_nascimento || '';
        document.getElementById('fCpf').value         = p.cpf || '';
        document.getElementById('fRg').value          = p.rg || '';
        document.getElementById('fSexo').value        = p.sexo || '';
        document.getElementById('fConvenio').value    = p.convenio || '';
        document.getElementById('fCep').value         = p.cep || '';
        document.getElementById('fEndereco').value    = p.endereco || '';
        document.getElementById('fResponsavel').value = p.responsavel || '';
        document.getElementById('fObservacoes').value = p.observacoes || '';
        document.getElementById('modalPaciente').style.display = 'block';
        document.body.style.overflow = 'hidden';
        document.getElementById('fNome').focus();
      })
      .catch(function () { alert('Não foi possível carregar os dados do paciente.'); });
  };

  // Modal importar
  window.abrirImport = function () {
    document.getElementById('modalImport').style.display = 'block';
    document.body.style.overflow = 'hidden';
  };
  window.fecharImport = function () {
    document.getElementById('modalImport').style.display = 'none';
    document.body.style.overflow = '';
  };

  // Fechar modais ao clicar fora
  document.getElementById('modalPaciente').addEventListener('click', function (e) {
    if (e.target === this) fecharModal();
  });
  document.getElementById('modalImport').addEventListener('click', function (e) {
    if (e.target === this) fecharImport();
  });

  // Validação de CPF (algoritmo mod 11)
  function validarCPF(cpf) {
    var s = cpf.replace(/\D/g, '');
    if (s.length !== 11 || /^(\d)\1{10}$/.test(s)) return false;
    var soma = 0;
    for (var i = 0; i < 9; i++) soma += parseInt(s[i]) * (10 - i);
    var r1 = (soma * 10) % 11; if (r1 === 10 || r1 === 11) r1 = 0;
    if (r1 !== parseInt(s[9])) return false;
    soma = 0;
    for (var i = 0; i < 10; i++) soma += parseInt(s[i]) * (11 - i);
    var r2 = (soma * 10) % 11; if (r2 === 10 || r2 === 11) r2 = 0;
    return r2 === parseInt(s[10]);
  }

  // Máscara CPF
  var cpfEl = document.getElementById('fCpf');
  var cpfErroEl = document.getElementById('cpfErro');
  cpfEl.addEventListener('input', function () {
    var v = this.value.replace(/\D/g, '').slice(0, 11);
    if (v.length > 9) v = v.slice(0,3)+'.'+v.slice(3,6)+'.'+v.slice(6,9)+'-'+v.slice(9);
    else if (v.length > 6) v = v.slice(0,3)+'.'+v.slice(3,6)+'.'+v.slice(6);
    else if (v.length > 3) v = v.slice(0,3)+'.'+v.slice(3);
    this.value = v;
    if (v.replace(/\D/g,'').length === 11) {
      cpfErroEl.style.display = validarCPF(v) ? 'none' : 'inline';
    } else {
      cpfErroEl.style.display = 'none';
    }
  });

  // Validação CPF no submit
  document.getElementById('formPaciente').addEventListener('submit', function (e) {
    var cpfVal = cpfEl.value.replace(/\D/g, '');
    if (cpfVal.length > 0 && !validarCPF(cpfEl.value)) {
      e.preventDefault();
      cpfErroEl.style.display = 'inline';
      cpfEl.focus();
    }
  });

  // Máscara CEP + busca automática ViaCEP
  var cepEl = document.getElementById('fCep');
  var cepErroEl = document.getElementById('cepErro');
  var cepSpinner = document.getElementById('cepSpinner');
  cepEl.addEventListener('input', function () {
    var v = this.value.replace(/\D/g, '').slice(0, 8);
    this.value = v.length > 5 ? v.slice(0, 5) + '-' + v.slice(5) : v;
    cepErroEl.style.display = 'none';
    if (v.length === 8) {
      cepSpinner.style.display = 'inline';
      fetch('https://viacep.com.br/ws/' + v + '/json/')
        .then(function (r) { return r.json(); })
        .then(function (d) {
          cepSpinner.style.display = 'none';
          if (d.erro) {
            cepErroEl.style.display = 'inline';
          } else {
            var end = d.logradouro || '';
            if (d.bairro) end += (end ? ', ' : '') + d.bairro;
            if (d.localidade) end += (end ? ' - ' : '') + d.localidade;
            if (d.uf) end += '/' + d.uf;
            document.getElementById('fEndereco').value = end;
          }
        })
        .catch(function () { cepSpinner.style.display = 'none'; });
    }
  });

  // Abrir modal de importação se houver notificação
  <% if (importError || importSuccess) { %>
  // resultado de importação visível na tela
  <% } %>
})();
</script>
</body>
</html>
