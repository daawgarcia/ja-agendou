<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Agente IA — Meta Ads</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { background: #0f1117; color: #e2e8f0; font-family: 'Segoe UI', system-ui, sans-serif; }
    .card { background: #1a1d27; border: 1px solid #2a2d3a; border-radius: 12px; }
    .prose h1, .prose h2, .prose h3 { color: #f1f5f9; font-weight: 700; margin: 1.2em 0 0.5em; }
    .prose h2 { font-size: 1.1rem; border-bottom: 1px solid #2a2d3a; padding-bottom: 0.3em; }
    .prose strong { color: #e2e8f0; }
    .prose p { margin: 0.6em 0; line-height: 1.7; color: #cbd5e1; }
    .prose ul { list-style: disc; padding-left: 1.5rem; margin: 0.5em 0; }
    .prose li { margin: 0.3em 0; color: #cbd5e1; }
    .prose code { background: #1e2130; padding: 0.1em 0.4em; border-radius: 4px; font-size: 0.88em; color: #a5b4fc; }
    .btn-analisar { background: linear-gradient(135deg, #6366f1, #8b5cf6); transition: opacity 0.2s; }
    .btn-analisar:hover { opacity: 0.85; }
    .loading-dots span { animation: blink 1.4s infinite both; }
    .loading-dots span:nth-child(2) { animation-delay: 0.2s; }
    .loading-dots span:nth-child(3) { animation-delay: 0.4s; }
    @keyframes blink { 0%, 80%, 100% { opacity: 0; } 40% { opacity: 1; } }
  </style>
</head>
<body class="min-h-screen p-6">

  <!-- Header -->
  <div class="flex items-center justify-between mb-8 flex-wrap gap-4">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl bg-indigo-600/20 border border-indigo-500/30 flex items-center justify-center text-xl">🤖</div>
      <div>
        <h1 class="text-2xl font-bold text-white">Agente IA — Meta Ads</h1>
        <p class="text-slate-400 text-sm">Análise inteligente das suas campanhas</p>
      </div>
    </div>
    <a href="/meta-ads" class="bg-slate-700 hover:bg-slate-600 text-white text-xs px-4 py-2 rounded-lg font-semibold transition-colors">
      ← Dashboard
    </a>
  </div>

  <% if (erro) { %>
  <div class="bg-red-900/30 border border-red-800 text-red-300 rounded-lg p-4 mb-6 text-sm">
    ⚠️ <%= erro %>
  </div>
  <% } %>

  <!-- Botão de análise -->
  <% if (!resultado) { %>
  <div class="card p-8 text-center max-w-xl mx-auto mt-16">

    <% if (diasDesde !== null && diasDesde < 7) { %>
    <div class="bg-amber-900/30 border border-amber-700/50 rounded-xl p-4 mb-6 text-left">
      <p class="text-amber-400 font-semibold text-sm mb-1">⏳ Campanhas muito recentes</p>
      <p class="text-amber-200/70 text-xs leading-relaxed">
        Sua campanha mais recente tem <strong class="text-amber-300"><%= diasDesde === 0 ? 'menos de 1 dia' : diasDesde + (diasDesde === 1 ? ' dia' : ' dias') %></strong>.
        O Meta precisa de pelo menos <strong class="text-amber-300">7 dias</strong> para sair da fase de aprendizado e gerar dados confiáveis.
        Você pode analisar agora, mas os resultados podem não refletir a performance real.
      </p>
      <div class="mt-3 bg-amber-900/20 rounded-lg p-2">
        <div class="flex justify-between text-xs text-amber-400 mb-1">
          <span>Hoje (<%= diasDesde %>d)</span>
          <span>Mínimo (7d)</span>
          <span>Ideal (14d)</span>
        </div>
        <div class="w-full bg-amber-900/40 rounded-full h-2">
          <div class="bg-amber-500 h-2 rounded-full transition-all" style="width: <%= Math.min(100, (diasDesde / 14) * 100) %>%"></div>
        </div>
      </div>
    </div>
    <% } %>

    <div class="text-5xl mb-4">🧠</div>
    <h2 class="text-xl font-bold text-white mb-2">Pronto para analisar suas campanhas</h2>
    <p class="text-slate-400 text-sm mb-6">O agente vai analisar os dados dos últimos 30 dias e gerar recomendações práticas para melhorar sua performance.</p>
    <form method="POST" action="/meta-ads/agente/analisar" id="form-analisar">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <button type="submit" id="btn-analisar" class="btn-analisar text-white font-bold px-8 py-3 rounded-xl text-base w-full">
        Analisar campanhas agora
      </button>
    </form>
    <p class="text-slate-500 text-xs mt-3">Leva cerca de 10–20 segundos</p>
  </div>
  <% } %>

  <!-- Resultado -->
  <% if (resultado) { %>
  <div class="grid grid-cols-3 gap-4 mb-6">
    <div class="card p-4 text-center">
      <p class="text-slate-400 text-xs mb-1">Total gasto (30d)</p>
      <p class="text-2xl font-bold text-emerald-400">R$ <%= parseFloat(resultado.resumo.totalGasto).toLocaleString('pt-BR', {minimumFractionDigits:2}) %></p>
    </div>
    <div class="card p-4 text-center">
      <p class="text-slate-400 text-xs mb-1">Leads gerados</p>
      <p class="text-2xl font-bold text-blue-400"><%= resultado.resumo.totalLeads %></p>
    </div>
    <div class="card p-4 text-center">
      <p class="text-slate-400 text-xs mb-1">Campanhas analisadas</p>
      <p class="text-2xl font-bold text-violet-400"><%= resultado.resumo.campanhas.length %></p>
    </div>
  </div>

  <div class="card p-6 mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-white font-bold text-lg flex items-center gap-2">🤖 Análise do Agente</h2>
      <span class="text-slate-500 text-xs">Gerado em <%= resultado.geradoEm %></span>
    </div>
    <div class="prose max-w-none" id="analise-content"></div>
  </div>

  <div class="card p-6 mb-6">
    <h2 class="text-white font-bold mb-4">📊 Dados por Campanha</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-slate-400 text-xs border-b border-slate-700">
            <th class="text-left pb-2 pr-4">Campanha</th>
            <th class="text-right pb-2 pr-4">Status</th>
            <th class="text-right pb-2 pr-4">Gasto</th>
            <th class="text-right pb-2 pr-4">Leads</th>
            <th class="text-right pb-2 pr-4">CTR</th>
            <th class="text-right pb-2 pr-4">CPC</th>
            <th class="text-right pb-2">Freq.</th>
          </tr>
        </thead>
        <tbody>
          <% resultado.resumo.campanhas.forEach(c => { %>
          <tr class="border-b border-slate-800 hover:bg-slate-800/30">
            <td class="py-2 pr-4 text-slate-200 max-w-xs truncate"><%= c.nome %></td>
            <td class="py-2 pr-4 text-right">
              <span class="px-2 py-0.5 rounded text-xs font-medium <%= c.status === 'ACTIVE' ? 'bg-emerald-900/50 text-emerald-400' : 'bg-slate-700 text-slate-400' %>">
                <%= c.status === 'ACTIVE' ? 'Ativa' : 'Pausada' %>
              </span>
            </td>
            <td class="py-2 pr-4 text-right text-emerald-400">R$ <%= parseFloat(c.gasto||0).toFixed(2) %></td>
            <td class="py-2 pr-4 text-right text-blue-400"><%= c.leads %></td>
            <td class="py-2 pr-4 text-right <%= parseFloat(c.ctr) >= 1.5 ? 'text-emerald-400' : parseFloat(c.ctr) < 0.8 ? 'text-red-400' : 'text-amber-400' %>">
              <%= parseFloat(c.ctr||0).toFixed(2) %>%
            </td>
            <td class="py-2 pr-4 text-right text-slate-300">R$ <%= parseFloat(c.cpc||0).toFixed(2) %></td>
            <td class="py-2 text-right <%= parseFloat(c.frequencia) > 3.5 ? 'text-red-400' : 'text-slate-300' %>">
              <%= parseFloat(c.frequencia||0).toFixed(1) %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="flex justify-center gap-3 flex-wrap">
    <form method="POST" action="/meta-ads/agente/analisar" id="form-reanalisar">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <button type="submit" class="btn-analisar text-white font-semibold px-6 py-2 rounded-lg text-sm">
        🔄 Reanalisar
      </button>
    </form>
    <button onclick="executarSemanal(this)" class="bg-emerald-700 hover:bg-emerald-600 text-white font-semibold px-6 py-2 rounded-lg text-sm transition-colors">
      ⚡ Executar análise completa + enviar e-mail
    </button>
  </div>
  <p class="text-center text-slate-500 text-xs mt-2">A análise completa executa ações automáticas e envia o relatório para otavio.garcia@outlook.com</p>

  <div id="semanal-resultado" class="card p-4 mt-4 hidden text-sm"></div>

  <script>
  async function executarSemanal(btn) {
    btn.disabled = true;
    btn.textContent = 'Executando...';
    document.getElementById('semanal-resultado').classList.add('hidden');
    try {
      const csrf = document.querySelector('#form-reanalisar input[name="_csrf"]')?.value || '';
      const res = await fetch('/meta-ads/agente/executar-semanal', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'x-csrf-token': csrf },
        body: JSON.stringify({}),
      });
      const data = await res.json();
      const el = document.getElementById('semanal-resultado');
      el.classList.remove('hidden');
      if (data.ok) {
        const acoes = data.acoesTomadas?.length > 0
          ? data.acoesTomadas.map(a => `<li>${a.acao}: ${a.campanha} — ${a.motivo}</li>`).join('')
          : '<li>Nenhuma ação automática necessária</li>';
        el.innerHTML = `<p class="text-emerald-400 font-semibold mb-2">✅ Concluído! ${data.emailEnviado ? 'E-mail enviado.' : 'E-mail não enviado (SMTP não configurado).'}</p><ul class="list-disc pl-4 text-slate-300">${acoes}</ul>`;
      } else {
        el.innerHTML = `<p class="text-red-400">❌ Erro: ${data.erro}</p>`;
      }
    } catch(e) {
      document.getElementById('semanal-resultado').innerHTML = `<p class="text-red-400">❌ Erro: ${e.message}</p>`;
      document.getElementById('semanal-resultado').classList.remove('hidden');
    }
    btn.disabled = false;
    btn.textContent = '⚡ Executar análise completa + enviar e-mail';
  }
  </script>

  <script>
    const texto = `<%- resultado.analise.replace(/`/g, '\\`').replace(/\\/g, '\\\\').replace(/\n/g, '\\n') %>`;
    const el = document.getElementById('analise-content');

    // Converte markdown simples para HTML
    const html = texto
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/^### (.+)$/gm, '<h3>$1</h3>')
      .replace(/^## (.+)$/gm, '<h2>$1</h2>')
      .replace(/^# (.+)$/gm, '<h1>$1</h1>')
      .replace(/^- (.+)$/gm, '<li>$1</li>')
      .replace(/(<li>.*<\/li>\n?)+/g, m => `<ul>${m}</ul>`)
      .replace(/\n\n/g, '</p><p>')
      .replace(/^(?!<[hul])/gm, '')
      .replace(/\n/g, '<br>');

    el.innerHTML = `<p>${html}</p>`;
  </script>
  <% } %>

  <script>
    const form1 = document.getElementById('form-analisar');
    const form2 = document.getElementById('form-reanalisar');
    [form1, form2].forEach(f => {
      if (!f) return;
      f.addEventListener('submit', () => {
        const btn = f.querySelector('button[type=submit]');
        btn.disabled = true;
        btn.innerHTML = 'Analisando <span class="loading-dots"><span>.</span><span>.</span><span>.</span></span>';
      });
    });
  </script>

</body>
</html>
